<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette anchors (user-specified):
         Header / DWM title bar:  #2E3440  rgb( 46,  52,  64)
         Window / client area:    #3B4453  rgb( 59,  68,  83)
         Selection highlight:     #0696D7  rgb(  6, 150, 215)
         Primary text:            #F5F5F5  rgb(245, 245, 245)  -->

    <SolidColorBrush x:Key="CheckupWindowBackground"            Color="#3B4453"/>
    <SolidColorBrush x:Key="CheckupRowBackground0"              Color="#3B4453"/>
    <SolidColorBrush x:Key="CheckupRowBackground1"              Color="#353D4C"/>
    <SolidColorBrush x:Key="CheckupPrimaryText"                 Color="#F5F5F5"/>
    <SolidColorBrush x:Key="CheckupSecondaryText"               Color="#8090A8"/>
    <SolidColorBrush x:Key="CheckupLabelText"                   Color="#9AAABB"/>
    <SolidColorBrush x:Key="CheckupErrorText"                   Color="#FF6B6B"/>
    <SolidColorBrush x:Key="CheckupSeparator"                   Color="#4A5365"/>
    <SolidColorBrush x:Key="CheckupButtonBackground"            Color="#2E3645"/>
    <SolidColorBrush x:Key="CheckupButtonBorder"                Color="#4A5570"/>
    <SolidColorBrush x:Key="CheckupButtonForeground"            Color="#F5F5F5"/>
    <SolidColorBrush x:Key="CheckupSpecialButtonBackground"     Color="#3D2A14"/>
    <SolidColorBrush x:Key="CheckupDestructiveButtonBackground" Color="#3D1820"/>
    <SolidColorBrush x:Key="CheckupApplyButtonBackground"       Color="#1A3A5C"/>
    <SolidColorBrush x:Key="CheckupCancelButtonBackground"      Color="#3D1820"/>
    <SolidColorBrush x:Key="CheckupActionItemForeground"        Color="#4CC2FF"/>
    <SolidColorBrush x:Key="CheckupGroupHeaderBackground"       Color="#2E3440"/>
    <SolidColorBrush x:Key="CheckupGroupHeaderForeground"       Color="#6A7A90"/>
    <SolidColorBrush x:Key="CheckupDragHandleFill"              Color="#5A6880"/>
    <SolidColorBrush x:Key="CheckupDragHighlight"               Color="#0696D7"/>
    <!-- Option C toggle-button active state tokens (§5.3, §5.8, §6.3) -->
    <SolidColorBrush x:Key="CheckupPresetActiveBorder"          Color="#0696D7"/>
    <SolidColorBrush x:Key="CheckupPresetActiveBackground"      Color="#1A0696D7"/>
    <!-- Selected item background that guarantees readable contrast for secondary text (#8090A8) -->
    <SolidColorBrush x:Key="CheckupSelectedCardBackground"      Color="#1A3660"/>
    <!-- Drag-over highlight background (Group border background when IsDragOver=True) -->
    <SolidColorBrush x:Key="CheckupSelectedRowBackground"       Color="#0A3D6E"/>
    <SolidColorBrush x:Key="CheckupLinkStripe"                  Color="#5BA3DE"/>
    <SolidColorBrush x:Key="CheckupSyncStripe"                  Color="#C8985A"/>
    <SolidColorBrush x:Key="CheckupComboItemBackground"         Color="#3B4453"/>
    <SolidColorBrush x:Key="CheckupComboItemHoverBackground"    Color="#0878B8"/>
    <SolidColorBrush x:Key="CheckupTabActiveBackground"          Color="#3B4453"/>
    <SolidColorBrush x:Key="CheckupTabInactiveBackground"        Color="#222933"/>

    <!-- Override WPF system brushes used by popup backgrounds and scrollbars.
         Scoped to this window's resources — does not affect other windows. -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"        Color="#3B4453"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"    Color="#F5F5F5"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"       Color="#3B4453"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"   Color="#F5F5F5"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"     Color="#0696D7"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#D8EEEB"/>

    <Style TargetType="TextBox">
        <Setter Property="Background"      Value="#2E3645"/>
        <Setter Property="Foreground"      Value="#F5F5F5"/>
        <Setter Property="BorderBrush"     Value="#4A5570"/>
        <Setter Property="CaretBrush"      Value="#F5F5F5"/>
        <Setter Property="SelectionBrush"  Value="#0696D7"/>
    </Style>

    <!-- Scrollbar colors (§5.15) -->
    <SolidColorBrush x:Key="CheckupScrollBarThumb"      Color="#5A6880"/>
    <SolidColorBrush x:Key="CheckupScrollBarThumbHover" Color="#8090A8"/>
    <!-- Alias used by LogicDropdownPopupContent border background -->
    <SolidColorBrush x:Key="CheckupComboBoxBackground"  Color="#3B4453"/>
    <!-- Background for editable TextBoxes inside custom panels (AllowedValues, Logic dropdown) -->
    <SolidColorBrush x:Key="CheckupEditableBackground"  Color="#2E3645"/>

    <!-- ─── Modern thin scrollbar (Windows 11 style) — §5.15 ─── -->
    <Style x:Key="ModernScrollBarThumb" TargetType="{x:Type Thumb}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid Background="Transparent">
                        <Border x:Name="ThumbBorder"
                                CornerRadius="3"
                                Background="{DynamicResource CheckupScrollBarThumb}"
                                Margin="2,2,2,2"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource CheckupScrollBarThumbHover}"/>
                            <Setter TargetName="ThumbBorder" Property="Margin"     Value="1,1,1,1"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource CheckupScrollBarThumbHover}"/>
                            <Setter TargetName="ThumbBorder" Property="Margin"     Value="1,1,1,1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernScrollBarPageButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="8"/>
                <Setter Property="Width"  Value="Auto"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Border Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ModernScrollBarPageButton}"
                                                      Command="ScrollBar.PageLeftCommand"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ModernScrollBarPageButton}"
                                                      Command="ScrollBar.PageRightCommand"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width"  Value="8"/>
                <Setter Property="Height" Value="Auto"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Border Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ModernScrollBarPageButton}"
                                                      Command="ScrollBar.PageUpCommand"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ModernScrollBarPageButton}"
                                                      Command="ScrollBar.PageDownCommand"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
