<Window x:Class="CheckupAddIn.Views.CatalogBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CheckupAddIn.Converters"
        Title="{DynamicResource Win_Title_LogicConstructor}"
        Width="1500" Height="1100"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CheckupWindowBackground}">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:GroupNameConverter       x:Key="GroupNameConverter"/>
        <conv:CardTypeToBrushConverter x:Key="CardTypeToBrushConverter"/>

        <!-- Full ComboBox ControlTemplate — DynamicResource colors work in both themes.
             Needed because WPF Aero2 renders the closed header with Windows chrome brushes
             that ignore the Background property, making the selection box white in dark mode. -->
        <Style TargetType="ComboBox">
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource CheckupComboItemBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
                        <Setter Property="Padding"    Value="6,3"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="HeaderBorder"
                                    Background="{DynamicResource CheckupButtonBackground}"
                                    BorderBrush="{DynamicResource CheckupButtonBorder}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="4,1,0,1"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      TextBlock.Foreground="{DynamicResource CheckupPrimaryText}"/>
                                    <Path Grid.Column="1"
                                          IsHitTestVisible="False"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M 0 0 L 3.5 4 L 7 0 Z"
                                          Fill="{DynamicResource CheckupSecondaryText}"/>
                                </Grid>
                            </Border>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   Focusable="False">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource CheckupComboItemBackground}"
                                        BorderBrush="{DynamicResource CheckupButtonBorder}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="False">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="HeaderBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="HeaderBorder" Property="BorderBrush"
                                        Value="{DynamicResource CheckupDragHighlight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab button: inactive = window background, active (IsEnabled=False) = 1px accent border + tint -->
        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="Foreground"      Value="{DynamicResource CheckupPrimaryText}"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="MinWidth"        Value="110"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                BorderThickness="1" BorderBrush="Transparent"
                                Background="{DynamicResource CheckupWindowBackground}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="BorderBrush"     Value="{DynamicResource CheckupPresetActiveBorder}"/>
                                <Setter TargetName="border" Property="Background"      Value="{DynamicResource CheckupPresetActiveBackground}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1,1,1,0"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Column header: letter + sort arrow + role badge on top row, user label below -->
        <DataTemplate x:Key="ColHeaderTemplate">
            <StackPanel Margin="0,1,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Letter}"
                               FontSize="9" FontWeight="Normal"
                               Foreground="{DynamicResource CheckupSecondaryText}"/>
                    <TextBlock Text="{Binding SortArrow}"
                               FontSize="9" FontWeight="Normal"
                               Foreground="{DynamicResource CheckupDragHighlight}"
                               Margin="2,0,0,0"/>
                    <!-- Role badge — colored pill, hidden when role is None -->
                    <Border Background="{Binding RoleBrush}"
                            CornerRadius="2" Padding="3,0"
                            Margin="4,0,0,0"
                            Visibility="{Binding HasRole, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding RoleBadge}"
                                   FontSize="8" FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="{Binding Label}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Label}"/>
            </StackPanel>
        </DataTemplate>

        <!-- Flat button used throughout this window -->
        <Style x:Key="CbBtn" TargetType="Button">
            <Setter Property="Background"   Value="{DynamicResource CheckupButtonBackground}"/>
            <Setter Property="Foreground"   Value="{DynamicResource CheckupButtonForeground}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource CheckupButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Margin"       Value="0,0,4,0"/>
            <Setter Property="MinWidth"     Value="32"/>
            <Setter Property="Height"       Value="26"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid row -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource CheckupRowBackground0}"/>
            <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource CheckupRowBackground1}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CheckupDragHighlight}"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid cell — selected cell gets a colored border (spreadsheet convention), no full-row highlight -->
        <Style TargetType="DataGridCell">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="{DynamicResource CheckupPrimaryText}"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background"  Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource CheckupDragHighlight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid column header — single click = sort, double-click = edit label
             Tag="selected" → subtle highlight when a cell in this column is selected -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"       Value="{DynamicResource CheckupGroupHeaderBackground}"/>
            <Setter Property="Foreground"       Value="{DynamicResource CheckupPrimaryText}"/>
            <Setter Property="Padding"          Value="6,4"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource CheckupSeparator}"/>
            <Setter Property="BorderThickness"  Value="0,0,1,1"/>
            <Setter Property="FontWeight"       Value="Normal"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <EventSetter Event="Click"               Handler="ColumnHeader_Click"/>
            <EventSetter Event="MouseRightButtonUp" Handler="ColumnHeader_MouseRightButtonUp"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="selected">
                    <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid row header — shows 1-based row number
             Tag="selected" → subtle highlight when a cell in this row is selected -->
        <Style TargetType="DataGridRowHeader">
            <Setter Property="Width"      Value="36"/>
            <Setter Property="Background" Value="{DynamicResource CheckupGroupHeaderBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource CheckupSecondaryText}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRowHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource CheckupSeparator}"
                                BorderThickness="0,0,1,0"
                                Padding="4,0">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontSize="10"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="selected">
                                <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Right-side collapsible panel (Basic Logics).
             ExpandDirection="Left": toggle strip lives on the right, content slides out to the left.
             All colors via DynamicResource so light/dark mode switching works. -->
        <!-- Full-width toggle strip for the card-types panel (mirrors Basic Logics header look) -->
        <Style x:Key="CardToggleStrip" TargetType="Button">
            <Setter Property="Background"             Value="{DynamicResource CheckupGroupHeaderBackground}"/>
            <Setter Property="BorderBrush"            Value="{DynamicResource CheckupSeparator}"/>
            <Setter Property="BorderThickness"        Value="0,1,0,0"/>
            <Setter Property="Padding"                Value="8,5"/>
            <Setter Property="Cursor"                 Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BasicLogicsExpander" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>

                            <!-- Collapsible content — Collapsed hides it so the Auto column shrinks to 0.
                                 Content appears to the LEFT of the always-visible toggle strip. -->
                            <Border x:Name="ContentSite"
                                    Grid.Column="0"
                                    MinWidth="120"
                                    BorderBrush="{DynamicResource CheckupSeparator}"
                                    BorderThickness="1,0,0,0"
                                    Padding="8,12,8,4"
                                    Background="{DynamicResource CheckupGroupHeaderBackground}"
                                    Visibility="Collapsed">
                                <ContentPresenter/>
                            </Border>

                            <!-- Always-visible toggle strip — stays on the far right edge of the window. -->
                            <Border Grid.Column="1"
                                    BorderBrush="{DynamicResource CheckupSeparator}"
                                    BorderThickness="1,0,0,0"
                                    Background="{DynamicResource CheckupGroupHeaderBackground}"
                                    Cursor="Hand"
                                    ToolTip="{DynamicResource Cap_Tip_ToggleBasicLogics}">
                                <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                              Focusable="False">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <DockPanel>
                                                    <!-- Chevron: < when collapsed (content hidden left), > when expanded (content shown left) -->
                                                    <Path x:Name="Chevron"
                                                          DockPanel.Dock="Bottom"
                                                          HorizontalAlignment="Center"
                                                          Margin="0,6"
                                                          Data="M 5 0 L 0 5 L 5 10"
                                                          Stroke="{DynamicResource CheckupSecondaryText}"
                                                          StrokeThickness="1.5"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"/>
                                                    <!-- Rotated label reads bottom-to-top -->
                                                    <TextBlock Text="{DynamicResource Cap_BasicLogicsTitle}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource CheckupSecondaryText}">
                                                        <TextBlock.LayoutTransform>
                                                            <RotateTransform Angle="-90"/>
                                                        </TextBlock.LayoutTransform>
                                                    </TextBlock>
                                                </DockPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Chevron" Property="Data" Value="M 0 0 L 5 5 L 0 10"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox item -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding"    Value="8,5"/>
            <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CheckupSelectedCardBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="180"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════
             LEFT PANEL — Tab strip + content
             ══════════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{DynamicResource CheckupGroupHeaderBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab strip -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource CheckupSeparator}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="{DynamicResource CatBuilder_Tab_Catalogs}"
                            Command="{Binding SwitchToCatalogsCommand}"
                            IsEnabled="{Binding IsCapabilitiesTab}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource TabBtn}"/>
                    <Button Grid.Column="1"
                            Content="{DynamicResource CatBuilder_Tab_Capabilities}"
                            Command="{Binding SwitchToCapabilitiesCommand}"
                            IsEnabled="{Binding IsCatalogsTab}"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource TabBtn}"/>
                </Grid>
            </Border>

            <!-- ── CATALOGS CONTENT ── -->
            <DockPanel Grid.Row="1"
                       Visibility="{Binding IsCatalogsTab, Converter={StaticResource BoolToVis}}">
                <!-- Action buttons -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource CheckupSeparator}"
                        BorderThickness="0,1,0,0"
                        Padding="6,6">
                    <WrapPanel>
                        <Button Content="{DynamicResource CatBuilder_Btn_New}"    Command="{Binding NewCatalogCommand}"    Style="{StaticResource CbBtn}" Margin="0,0,4,4"/>
                        <Button Content="✎"                                         Command="{Binding RenameCatalogCommand}" Style="{StaticResource CbBtn}" ToolTip="{DynamicResource CatBuilder_Tip_Rename}" Margin="0,0,4,4"/>
                        <Button Content="×"                                         Command="{Binding DeleteCatalogCommand}" Style="{StaticResource CbBtn}" ToolTip="{DynamicResource CatBuilder_Tip_Delete}" Margin="0,0,4,4"/>
                        <Button Content="{DynamicResource CatBuilder_Btn_Import}"  Command="{Binding ImportCatalogCommand}" Style="{StaticResource CbBtn}" Margin="0,0,4,0"/>
                        <Button Content="{DynamicResource CatBuilder_Btn_Export}"  Command="{Binding ExportCatalogCommand}" Style="{StaticResource CbBtn}" Margin="0"/>
                    </WrapPanel>
                </Border>
                <!-- Lock strip — always visible when a catalog is selected -->
                <Border DockPanel.Dock="Bottom"
                        Padding="6,4"
                        Background="{DynamicResource CheckupGroupHeaderBackground}"
                        BorderBrush="{DynamicResource CheckupSeparator}"
                        BorderThickness="0,1,0,0"
                        Visibility="{Binding HasSelectedCatalog, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <!-- Update available row -->
                        <DockPanel Visibility="{Binding IsSelectedCatalogUpdateAvailable, Converter={StaticResource BoolToVis}}">
                            <Button DockPanel.Dock="Right"
                                    Content="{DynamicResource CatBuilder_Btn_Update}"
                                    Command="{Binding UpdateCatalogCommand}"
                                    Style="{StaticResource CbBtn}" Margin="0" FontSize="10"/>
                            <TextBlock Text="{DynamicResource CatBuilder_Lbl_UpdateAvailable}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                       FontSize="11"/>
                        </DockPanel>
                        <!-- Locked row -->
                        <DockPanel Visibility="{Binding IsSelectedCatalogLockedNoUpdate, Converter={StaticResource BoolToVis}}">
                            <Button DockPanel.Dock="Right"
                                    Content="{DynamicResource CatBuilder_Btn_Unlock}"
                                    Command="{Binding ToggleCatalogLockCommand}"
                                    Style="{StaticResource CbBtn}" Margin="0" FontSize="10"/>
                            <TextBlock Text="{DynamicResource CatBuilder_Lbl_Locked}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource CheckupErrorText}"
                                       FontWeight="SemiBold"
                                       FontSize="11"/>
                        </DockPanel>
                        <!-- Unlocked row -->
                        <DockPanel>
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelectedCatalogLocked}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>
                            <Button DockPanel.Dock="Right"
                                    Content="{DynamicResource CatBuilder_Btn_Lock}"
                                    Command="{Binding ToggleCatalogLockCommand}"
                                    Style="{StaticResource CbBtn}" Margin="0" FontSize="10"/>
                            <TextBlock Text="{DynamicResource CatBuilder_Lbl_Unlocked}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                       FontSize="11"/>
                        </DockPanel>
                    </Grid>
                </Border>
                <!-- Catalog list -->
                <ListBox ItemsSource="{Binding Catalogs}"
                         SelectedItem="{Binding SelectedCatalog}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        ToolTip="{Binding LastUpdatedDisplay}">
                                <!-- 💾 = AppData/local   🌐 = UNC distribution path -->
                                <TextBlock FontFamily="Segoe UI Emoji" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="💾"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnUncPath}" Value="True">
                                                    <Setter Property="Text" Value="🌐"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource CheckupPrimaryText}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- ── CAPABILITIES CONTENT ── -->
            <DockPanel Grid.Row="1"
                       Visibility="{Binding IsCapabilitiesTab, Converter={StaticResource BoolToVis}}">
                <!-- Action buttons -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="{DynamicResource CheckupSeparator}"
                        BorderThickness="0,1,0,0"
                        Padding="6,6">
                    <WrapPanel>
                        <Button Content="{DynamicResource CatBuilder_Btn_New}"    Command="{Binding NewCapSetCommand}"    Style="{StaticResource CbBtn}" Margin="0,0,4,4"/>
                        <Button Content="✎"                                         Command="{Binding RenameCapSetCommand}" Style="{StaticResource CbBtn}" ToolTip="{DynamicResource CatBuilder_Tip_Rename}" Margin="0,0,4,4"/>
                        <Button Content="×"                                         Command="{Binding DeleteCapSetCommand}" Style="{StaticResource CbBtn}" ToolTip="{DynamicResource CatBuilder_Tip_Delete}" Margin="0,0,4,4"/>
                        <Button Content="{DynamicResource CatBuilder_Btn_Import}"  Command="{Binding ImportCapSetCommand}" Style="{StaticResource CbBtn}" Margin="0,0,4,0"/>
                        <Button Content="{DynamicResource CatBuilder_Btn_Export}"  Command="{Binding ExportCapSetCommand}" Style="{StaticResource CbBtn}" Margin="0"/>
                    </WrapPanel>
                </Border>
                <!-- Lock strip — always visible when a capability set is selected -->
                <Border DockPanel.Dock="Bottom"
                        Padding="6,4"
                        Background="{DynamicResource CheckupGroupHeaderBackground}"
                        BorderBrush="{DynamicResource CheckupSeparator}"
                        BorderThickness="0,1,0,0"
                        Visibility="{Binding HasSelectedCapabilitySet, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <!-- Update available row -->
                        <DockPanel Visibility="{Binding IsSelectedCapSetUpdateAvailable, Converter={StaticResource BoolToVis}}">
                            <Button DockPanel.Dock="Right"
                                    Content="{DynamicResource CatBuilder_Btn_Update}"
                                    Command="{Binding UpdateCapSetCommand}"
                                    Style="{StaticResource CbBtn}" Margin="0" FontSize="10"/>
                            <TextBlock Text="{DynamicResource CatBuilder_Lbl_UpdateAvailable}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                       FontSize="11"/>
                        </DockPanel>
                        <!-- Locked row -->
                        <DockPanel Visibility="{Binding IsSelectedCapSetLockedNoUpdate, Converter={StaticResource BoolToVis}}">
                            <Button DockPanel.Dock="Right"
                                    Content="{DynamicResource CatBuilder_Btn_Unlock}"
                                    Command="{Binding ToggleCapSetLockCommand}"
                                    Style="{StaticResource CbBtn}" Margin="0" FontSize="10"/>
                            <TextBlock Text="{DynamicResource CatBuilder_Lbl_Locked}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource CheckupErrorText}"
                                       FontWeight="SemiBold"
                                       FontSize="11"/>
                        </DockPanel>
                        <!-- Unlocked row -->
                        <DockPanel>
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelectedCapSetLocked}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>
                            <Button DockPanel.Dock="Right"
                                    Content="{DynamicResource CatBuilder_Btn_Lock}"
                                    Command="{Binding ToggleCapSetLockCommand}"
                                    Style="{StaticResource CbBtn}" Margin="0" FontSize="10"/>
                            <TextBlock Text="{DynamicResource CatBuilder_Lbl_Unlocked}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                       FontSize="11"/>
                        </DockPanel>
                    </Grid>
                </Border>
                <!-- Capability set list -->
                <ListBox ItemsSource="{Binding CapabilitySets}"
                         SelectedItem="{Binding SelectedCapabilitySet}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        ToolTip="{Binding LastUpdatedDisplay}">
                                <!-- 💾 = AppData/local   🌐 = UNC distribution path -->
                                <TextBlock FontFamily="Segoe UI Emoji" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="💾"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnUncPath}" Value="True">
                                                    <Setter Property="Text" Value="🌐"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{DynamicResource CheckupPrimaryText}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>

        <!-- ══════════════════════════════════════════
             SPLITTER
             ══════════════════════════════════════════ -->
        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource CheckupSeparator}"/>

        <!-- ══════════════════════════════════════════
             RIGHT PANEL — Entry Editor / Cap placeholder
             ══════════════════════════════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Find bar — Ctrl+F opens above DataGrid on Catalogs tab -->
                <RowDefinition Height="*"/>      <!-- Main content -->
                <RowDefinition Height="Auto"/>   <!-- Action bar -->
            </Grid.RowDefinitions>

            <!-- Find bar — Ctrl+F / opens above DataGrid on Catalogs tab -->
            <Border x:Name="FindBar"
                    Grid.Row="0"
                    Height="32"
                    Background="{DynamicResource CheckupGroupHeaderBackground}"
                    BorderBrush="{DynamicResource CheckupSeparator}"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed"
                    Padding="8,0">
                <DockPanel VerticalAlignment="Center">
                    <TextBlock DockPanel.Dock="Left"
                               Text="🔍"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource CheckupSecondaryText}"
                               Margin="0,0,6,0"/>
                    <Button x:Name="FindCloseBtn"
                            DockPanel.Dock="Right"
                            Content="×"
                            Style="{StaticResource CbBtn}"
                            Width="26" Height="22" MinWidth="0"
                            Padding="0" Margin="2,0,0,0"
                            Click="FindClose_Click"/>
                    <Button x:Name="FindNextBtn"
                            DockPanel.Dock="Right"
                            Content="▼"
                            Style="{StaticResource CbBtn}"
                            Width="26" Height="22" MinWidth="0"
                            Padding="0" Margin="2,0,0,0"
                            Click="FindNext_Click"/>
                    <Button x:Name="FindPrevBtn"
                            DockPanel.Dock="Right"
                            Content="▲"
                            Style="{StaticResource CbBtn}"
                            Width="26" Height="22" MinWidth="0"
                            Padding="0" Margin="2,0,0,0"
                            Click="FindPrev_Click"/>
                    <TextBlock x:Name="FindCounter"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               FontSize="11"
                               Foreground="{DynamicResource CheckupSecondaryText}"
                               Margin="8,0"/>
                    <TextBox x:Name="FindBox"
                             VerticalAlignment="Center"
                             Height="22" Padding="4,2" FontSize="11"
                             Background="{DynamicResource CheckupWindowBackground}"
                             Foreground="{DynamicResource CheckupPrimaryText}"
                             BorderBrush="{DynamicResource CheckupButtonBorder}"
                             BorderThickness="1"
                             TextChanged="FindBox_TextChanged"
                             PreviewKeyDown="FindBox_PreviewKeyDown"/>
                </DockPanel>
            </Border>

            <!-- ── CAPABILITIES PANEL ── -->
            <Grid Grid.Row="1"
                  Background="{DynamicResource CheckupWindowBackground}"
                  Visibility="{Binding IsCapabilitiesTab, Converter={StaticResource BoolToVis}}">

                <!-- No logic set selected -->
                <TextBlock Text="{DynamicResource CatBuilder_Cap_SelectHint}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource CheckupSecondaryText}"
                           FontStyle="Italic"
                           Visibility="{Binding HasNoSelectedCapabilitySet, Converter={StaticResource BoolToVis}}"/>

                <!-- Selected logic set detail panel -->
                <Grid Visibility="{Binding HasSelectedCapabilitySet, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Content area: info strip + groups + bottom bar (left column) -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Expert Mode info strip — visible when any group is Expert -->
                        <Border Grid.Row="0"
                                Background="#4A3C00"
                                BorderBrush="#D4A017" BorderThickness="0,0,0,1"
                                Padding="12,5"
                                Visibility="{Binding HasAnyExpertGroup, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{DynamicResource Cap_ExpertModeInfoStrip}"
                                       Foreground="#FFDD44"
                                       FontSize="11"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Scrollable groups list -->
                        <ScrollViewer Grid.Row="1"
                                      x:Name="CapabilitiesScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Padding="16,12,16,4"
                                      PreviewMouseWheel="CapabilitiesScrollViewer_PreviewMouseWheel">
                        <StackPanel>
                            <!-- No groups placeholder -->
                            <TextBlock Text="{DynamicResource CatBuilder_Cap_NoCards}"
                                       HorizontalAlignment="Center"
                                       Margin="0,20"
                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                       FontStyle="Italic"
                                       Visibility="{Binding HasNoCapSetGroups, Converter={StaticResource BoolToVis}}"/>

                            <!-- Groups (each group = one Checkup row) -->
                            <ItemsControl x:Name="GroupsItemsControl"
                                          ItemsSource="{Binding CapSetGroups}"
                                          Visibility="{Binding HasCapSetGroups, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- V1: optional Expert section divider + Group section — DataContext = CardGroupVm -->
                                        <StackPanel>
                                            <Border Margin="0,4,0,8"
                                                    Padding="8,3"
                                                    Background="#D4A017"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Stretch"
                                                    Visibility="{Binding IsFirstExpert, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{DynamicResource Cap_SectionExpert}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        <Border Margin="0,0,0,8"
                                                AllowDrop="True"
                                                DragEnter="Group_DragEnter"
                                                DragLeave="Group_DragLeave"
                                                Drop="Group_Drop"
                                                PreviewMouseLeftButtonDown="Group_PreviewMouseLeftButtonDown">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"      Value="{DynamicResource CheckupWindowBackground}"/>
                                                    <Setter Property="BorderBrush"     Value="{DynamicResource CheckupSeparator}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource CheckupSelectedRowBackground}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsInactive}" Value="True">
                                                            <Setter Property="Opacity" Value="0.45"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="BorderBrush"     Value="{Binding AccentBrush}"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4"/>  <!-- F1: accent strip -->
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- F1: 4px color tip (amber when IsExpert, AccentBrush otherwise) -->
                                                <Rectangle Grid.Column="0" IsHitTestVisible="False" VerticalAlignment="Stretch">
                                                    <Rectangle.Style>
                                                        <Style TargetType="Rectangle">
                                                            <Setter Property="Fill" Value="{Binding AccentBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpert}" Value="True">
                                                                    <Setter Property="Fill" Value="#D4A017"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Rectangle.Style>
                                                </Rectangle>

                                            <StackPanel Grid.Column="1">
                                                <!-- Group header: chevron + # + drag handle + Name/Pills + ⚡ + delete + TargetField + ▲▼⧉× -->
                                                <Border BorderBrush="{DynamicResource CheckupSeparator}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="6,5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>              <!-- chevron -->
                                                            <ColumnDefinition Width="Auto"/>              <!-- # order number -->
                                                            <ColumnDefinition Width="Auto"/>              <!-- drag handle -->
                                                            <ColumnDefinition Width="*" MinWidth="100"/>  <!-- name (expanded) OR label+pills (collapsed) -->
                                                            <ColumnDefinition Width="Auto"/>              <!-- ⚡ expert toggle -->
                                                            <ColumnDefinition Width="Auto"/>              <!-- × delete (expanded only) -->
                                                            <ColumnDefinition Width="Auto" MinWidth="0"/>  <!-- target field (expanded only) -->
                                                            <ColumnDefinition Width="Auto"/>              <!-- ▲▼⧉× (collapsed only) -->
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Chevron collapse button (always visible) -->
                                                        <Button Grid.Column="0"
                                                                Command="{Binding ToggleCollapseCommand}"
                                                                Style="{StaticResource CbBtn}"
                                                                Width="20" Height="20"
                                                                Padding="0"
                                                                Margin="0,0,4,0"
                                                                ToolTip="{DynamicResource Cap_Tip_ToggleCollapse}">
                                                            <Path Stroke="{DynamicResource CheckupSecondaryText}"
                                                                  StrokeThickness="1.5"
                                                                  StrokeLineJoin="Round"
                                                                  Fill="Transparent"
                                                                  VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Data" Value="M 0 0 L 5 5 L 10 0"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                                <Setter Property="Data" Value="M 0 0 L 5 5 L 0 10"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                        </Button>

                                                        <!-- Order number (always visible) -->
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding OrderNumber}"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="11"
                                                                   MinWidth="18"
                                                                   TextAlignment="Center"
                                                                   Margin="0,0,4,0"
                                                                   Foreground="{DynamicResource CheckupSecondaryText}"/>

                                                        <!-- Drag handle (2×3 dots) -->
                                                        <Border Grid.Column="2"
                                                                Cursor="SizeAll"
                                                                Background="Transparent"
                                                                Margin="0,0,6,0"
                                                                MouseMove="GroupDragHandle_MouseMove"
                                                                ToolTip="{DynamicResource Tip_DragReorder}">
                                                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                  Width="10" Height="14">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="*"/>
                                                                    <RowDefinition Height="*"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Ellipse Grid.Row="0" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                <Ellipse Grid.Row="1" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                <Ellipse Grid.Row="2" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                <Ellipse Grid.Row="0" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                <Ellipse Grid.Row="1" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                <Ellipse Grid.Row="2" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                            </Grid>
                                                        </Border>

                                                        <!-- Column 3: Name TextBox (expanded) OR Label+Pills (collapsed) -->
                                                        <Grid Grid.Column="3" Margin="0,0,8,0">
                                                            <!-- Expanded: name textbox -->
                                                            <Grid>
                                                                <Grid.Style>
                                                                    <Style TargetType="Grid">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Grid.Style>
                                                                <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                         Height="26"
                                                                         Padding="3,0"
                                                                         VerticalContentAlignment="Center"
                                                                         ToolTip="{DynamicResource CatBuilder_Cap_GroupName}">
                                                                    <TextBox.Style>
                                                                        <Style TargetType="TextBox">
                                                                            <Style.Triggers>
                                                                                <Trigger Property="Text" Value="">
                                                                                    <Setter Property="BorderBrush" Value="#CC4444"/>
                                                                                </Trigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBox.Style>
                                                                </TextBox>
                                                                <!-- Placeholder hint when empty -->
                                                                <TextBlock Text="{DynamicResource CatBuilder_Cap_GroupNameHint}"
                                                                           IsHitTestVisible="False"
                                                                           VerticalAlignment="Center"
                                                                           Margin="5,0,0,0"
                                                                           FontStyle="Italic"
                                                                           Foreground="#886688AA">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Name}" Value="">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                            <!-- Collapsed: Name + Expert badge + CardTypePills -->
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <StackPanel.Style>
                                                                    <Style TargetType="StackPanel">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </StackPanel.Style>
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontWeight="SemiBold"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource CheckupPrimaryText}"
                                                                           Margin="0,0,8,0"/>
                                                                <Border CornerRadius="3" Padding="6,1" Margin="0,0,4,0" VerticalAlignment="Center"
                                                                        Background="#D4A017"
                                                                        Visibility="{Binding IsExpert, Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock Text="{DynamicResource Cap_BadgeExpert}"
                                                                               FontSize="10" FontWeight="Bold" Foreground="White"/>
                                                                </Border>
                                                                <ItemsControl ItemsSource="{Binding CardTypePills}" VerticalAlignment="Center">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Background="{Binding Type, Converter={StaticResource CardTypeToBrushConverter}}"
                                                                                    CornerRadius="3" Padding="6,1" Margin="0,0,4,0"
                                                                                    VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding Label}"
                                                                                           FontSize="10"
                                                                                           FontWeight="SemiBold"
                                                                                           Foreground="White"/>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Grid>

                                                        <!-- ⚡ Expert toggle (always visible) — amber + topo label when IsExpert -->
                                                        <Button Grid.Column="4"
                                                                Command="{Binding ToggleExpertCommand}"
                                                                MinWidth="24" Height="24"
                                                                Padding="3,0"
                                                                Margin="0,0,6,0"
                                                                ToolTip="{DynamicResource Cap_TipExpertToggle}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="⚡" FontSize="12" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding ExpertTopoLabel}"
                                                                           FontSize="9" FontWeight="Bold"
                                                                           VerticalAlignment="Bottom" Margin="1,0,0,1"
                                                                           Visibility="{Binding HasExpertTopoLabel, Converter={StaticResource BoolToVis}}"/>
                                                            </StackPanel>
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource CbBtn}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpert}" Value="True">
                                                                            <Setter Property="Foreground" Value="#D4A017"/>
                                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>

                                                        <!-- Delete group button (expanded only) -->
                                                        <Button Grid.Column="5"
                                                                Content="×"
                                                                Command="{Binding RemoveGroupCommand}"
                                                                Width="24" Height="24"
                                                                Padding="0"
                                                                Margin="0,0,8,0"
                                                                ToolTip="{DynamicResource CatBuilder_Tip_Delete}">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource CbBtn}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>

                                                        <!-- Target Field selector (expanded only) — enhanced popup (P3-B) -->
                                                        <DockPanel Grid.Column="6" MinWidth="160" HorizontalAlignment="Left">
                                                            <DockPanel.Style>
                                                                <Style TargetType="DockPanel">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Width" Value="Auto"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </DockPanel.Style>
                                                            <TextBlock DockPanel.Dock="Left"
                                                                       Text="{DynamicResource CatBuilder_Cap_TargetField}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,6,0"
                                                                       Foreground="{DynamicResource CheckupSecondaryText}"/>
                                                            <Grid>
                                                                <!-- Header button — shows current selection, opens picker popup -->
                                                                <Button x:Name="TfPickerBtn"
                                                                        Click="TargetFieldBtn_Click"
                                                                        FontSize="11"
                                                                        Background="{DynamicResource CheckupButtonBackground}"
                                                                        Foreground="{DynamicResource CheckupPrimaryText}"
                                                                        BorderBrush="{DynamicResource CheckupButtonBorder}"
                                                                        Height="26"
                                                                        Padding="4,0,2,0">
                                                                    <Button.Template>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border x:Name="bdr"
                                                                                    Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="1">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="16"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock Grid.Column="0"
                                                                                               Text="{Binding TargetFieldDropText}"
                                                                                               FontSize="11"
                                                                                               Padding="4,0,2,0"
                                                                                               VerticalAlignment="Center"
                                                                                               TextTrimming="CharacterEllipsis"/>
                                                                                    <Path Grid.Column="1"
                                                                                          IsHitTestVisible="False"
                                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                          Data="M 0 0 L 3.5 4 L 7 0 Z"
                                                                                          Fill="{DynamicResource CheckupSecondaryText}"/>
                                                                                </Grid>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource CheckupDragHighlight}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Button.Template>
                                                                </Button>

                                                                <!-- Custom picker popup: Zone 1 Search + Zone 3 Favoriten + Zone 4 Groups -->
                                                                <Popup PlacementTarget="{Binding ElementName=TfPickerBtn}"
                                                                       Placement="Bottom"
                                                                       IsOpen="{Binding IsTargetFieldPickerOpen, Mode=TwoWay}"
                                                                       StaysOpen="False"
                                                                       AllowsTransparency="True"
                                                                       Opened="TargetFieldPopup_Opened"
                                                                       Closed="TargetFieldPopup_Closed">
                                                                    <Border MinWidth="150" MinHeight="80"
                                                                            Background="{DynamicResource CheckupComboItemBackground}"
                                                                            BorderBrush="{DynamicResource CheckupButtonBorder}"
                                                                            BorderThickness="1">
                                                                        <Grid>
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="*"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                            </Grid.RowDefinitions>

                                                                            <!-- Zone 1: Search box -->
                                                                            <TextBox Grid.Row="0"
                                                                                     Text="{Binding TargetFieldPickerFilter, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Margin="4,4,4,2" Padding="4,3" FontSize="11" Height="26"
                                                                                     TextWrapping="NoWrap" VerticalAlignment="Top" BorderThickness="1">
                                                                                <TextBox.Style>
                                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                                        <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
                                                                                    </Style>
                                                                                </TextBox.Style>
                                                                            </TextBox>

                                                                            <!-- Separator before Favoriten -->
                                                                            <Separator Grid.Row="1" Margin="4,0" Background="{DynamicResource CheckupButtonBorder}">
                                                                                <Separator.Style>
                                                                                    <Style TargetType="Separator">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding HasTargetFieldPickerFavoriten}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Separator.Style>
                                                                            </Separator>

                                                                            <!-- Zone 3: Favoriten -->
                                                                            <ItemsControl Grid.Row="2"
                                                                                          ItemsSource="{Binding TargetFieldPickerFavoriten}">
                                                                                <ItemsControl.Style>
                                                                                    <Style TargetType="ItemsControl">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding HasTargetFieldPickerFavoriten}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </ItemsControl.Style>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <Border Background="Transparent"
                                                                                                AllowDrop="True"
                                                                                                DragEnter="TfFavoritenItem_DragEnter"
                                                                                                Drop="TfFavoritenItem_Drop"
                                                                                                MouseRightButtonUp="TargetFieldPickerItem_RightClick"
                                                                                                ToolTip="{DynamicResource FieldSel_PinTooltip}">
                                                                                            <Border.Style>
                                                                                                <Style TargetType="Border">
                                                                                                    <Style.Triggers>
                                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                                            <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                                                        </Trigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </Border.Style>
                                                                                            <Grid>
                                                                                                <Grid.ColumnDefinitions>
                                                                                                    <ColumnDefinition Width="18"/>
                                                                                                    <ColumnDefinition Width="*"/>
                                                                                                </Grid.ColumnDefinitions>
                                                                                                <TextBlock Grid.Column="0"
                                                                                                           Text="≡" FontSize="10"
                                                                                                           Foreground="{DynamicResource CheckupDragHandleFill}"
                                                                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                                                           Cursor="SizeNS"
                                                                                                           MouseMove="TfFavoritenDragHandle_MouseMove"/>
                                                                                                <Button Grid.Column="1"
                                                                                                        Click="TargetFieldPickerPinned_Click"
                                                                                                        Cursor="Hand" Padding="0">
                                                                                                    <Button.Template>
                                                                                                        <ControlTemplate TargetType="Button">
                                                                                                            <Border Background="Transparent">
                                                                                                                <TextBlock x:Name="txt"
                                                                                                                           Text="{Binding DropText}"
                                                                                                                           FontSize="11"
                                                                                                                           Foreground="{DynamicResource CheckupPrimaryText}"
                                                                                                                           Padding="2,3,6,3"/>
                                                                                                            </Border>
                                                                                                            <ControlTemplate.Triggers>
                                                                                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                                                                    <Setter TargetName="txt" Property="TextDecorations" Value="Strikethrough"/>
                                                                                                                    <Setter TargetName="txt" Property="Foreground" Value="{DynamicResource CheckupSecondaryText}"/>
                                                                                                                </DataTrigger>
                                                                                                            </ControlTemplate.Triggers>
                                                                                                        </ControlTemplate>
                                                                                                    </Button.Template>
                                                                                                </Button>
                                                                                            </Grid>
                                                                                        </Border>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>

                                                                            <!-- Separator before groups -->
                                                                            <Separator Grid.Row="3" Margin="4,0"
                                                                                       Background="{DynamicResource CheckupButtonBorder}"/>

                                                                            <!-- Zone 4: Scrollable collapsible groups -->
                                                                            <ScrollViewer Grid.Row="4"
                                                                                          VerticalScrollBarVisibility="Auto"
                                                                                          CanContentScroll="False">
                                                                                <ItemsControl ItemsSource="{Binding TargetFieldPickerGroups}">
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <StackPanel>
                                                                                                <Button Click="TargetFieldPickerGroupHeader_Click"
                                                                                                        HorizontalContentAlignment="Left"
                                                                                                        Padding="0"
                                                                                                        IsEnabled="{Binding IsChevronEnabled}">
                                                                                                    <Button.Template>
                                                                                                        <ControlTemplate TargetType="Button">
                                                                                                            <Border Background="{DynamicResource CheckupGroupHeaderBackground}">
                                                                                                                <Grid>
                                                                                                                    <Grid.ColumnDefinitions>
                                                                                                                        <ColumnDefinition Width="16"/>
                                                                                                                        <ColumnDefinition Width="*"/>
                                                                                                                    </Grid.ColumnDefinitions>
                                                                                                                    <TextBlock Grid.Column="0"
                                                                                                                               x:Name="chevron" Text="▶" FontSize="8"
                                                                                                                               Foreground="{DynamicResource CheckupGroupHeaderForeground}"
                                                                                                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                                                                    <TextBlock Grid.Column="1"
                                                                                                                               Text="{Binding GroupDisplayName}"
                                                                                                                               FontSize="10" FontWeight="Bold"
                                                                                                                               Foreground="{DynamicResource CheckupGroupHeaderForeground}"
                                                                                                                               Padding="2,2,6,2"/>
                                                                                                                </Grid>
                                                                                                            </Border>
                                                                                                            <ControlTemplate.Triggers>
                                                                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                                                    <Setter TargetName="chevron" Property="Text" Value="▼"/>
                                                                                                                </DataTrigger>
                                                                                                                <Trigger Property="IsEnabled" Value="False">
                                                                                                                    <Setter TargetName="chevron" Property="Visibility" Value="Collapsed"/>
                                                                                                                </Trigger>
                                                                                                            </ControlTemplate.Triggers>
                                                                                                        </ControlTemplate>
                                                                                                    </Button.Template>
                                                                                                </Button>
                                                                                                <ItemsControl ItemsSource="{Binding FilteredItems}" AlternationCount="2">
                                                                                                    <ItemsControl.Style>
                                                                                                        <Style TargetType="ItemsControl">
                                                                                                            <Style.Triggers>
                                                                                                                <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                                </DataTrigger>
                                                                                                            </Style.Triggers>
                                                                                                        </Style>
                                                                                                    </ItemsControl.Style>
                                                                                                    <ItemsControl.ItemTemplate>
                                                                                                        <DataTemplate>
                                                                                                            <Grid>
                                                                                                                <Border x:Name="rowBg" Background="{DynamicResource CheckupRowBackground0}"/>
                                                                                                                <Button Click="TargetFieldPickerItem_Click"
                                                                                                                        MouseRightButtonUp="TargetFieldPickerItem_RightClick"
                                                                                                                        HorizontalContentAlignment="Left"
                                                                                                                        Padding="0" Cursor="Hand"
                                                                                                                        ToolTip="{DynamicResource FieldSel_PinTooltip}">
                                                                                                                    <Button.Template>
                                                                                                                        <ControlTemplate TargetType="Button">
                                                                                                                            <Border x:Name="bdr" Background="Transparent">
                                                                                                                                <DockPanel LastChildFill="True">
                                                                                                                                    <Rectangle DockPanel.Dock="Bottom"
                                                                                                                                               Height="1"
                                                                                                                                               Stroke="{DynamicResource CheckupSeparator}"
                                                                                                                                               StrokeThickness="1"
                                                                                                                                               StrokeDashArray="1 2"
                                                                                                                                               SnapsToDevicePixels="True"/>
                                                                                                                                    <TextBlock Text="{Binding DropText}"
                                                                                                                                               FontSize="11"
                                                                                                                                               Foreground="{DynamicResource CheckupPrimaryText}"
                                                                                                                                               Padding="14,3,6,2"/>
                                                                                                                                </DockPanel>
                                                                                                                            </Border>
                                                                                                                            <ControlTemplate.Triggers>
                                                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                                                    <Setter TargetName="bdr" Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                                                                                </Trigger>
                                                                                                                            </ControlTemplate.Triggers>
                                                                                                                        </ControlTemplate>
                                                                                                                    </Button.Template>
                                                                                                                </Button>
                                                                                                            </Grid>
                                                                                                            <DataTemplate.Triggers>
                                                                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                                                                                                                    <Setter TargetName="rowBg" Property="Background" Value="{DynamicResource CheckupRowBackground1}"/>
                                                                                                                </DataTrigger>
                                                                                                            </DataTemplate.Triggers>
                                                                                                        </DataTemplate>
                                                                                                    </ItemsControl.ItemTemplate>
                                                                                                </ItemsControl>
                                                                                            </StackPanel>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>
                                                                            </ScrollViewer>

                                                                            <!-- Resize grip (height only — width auto-sizes to content) -->
                                                                            <Thumb Grid.Row="5"
                                                                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                                   Width="12" Height="12" Cursor="SizeNS"
                                                                                   DragDelta="TargetFieldResizeThumb_DragDelta">
                                                                                <Thumb.Template>
                                                                                    <ControlTemplate TargetType="Thumb">
                                                                                        <Path Data="M 0 12 L 12 0 M 4 12 L 12 4 M 8 12 L 12 8"
                                                                                              Stroke="{DynamicResource CheckupSecondaryText}"
                                                                                              StrokeThickness="1.5"/>
                                                                                    </ControlTemplate>
                                                                                </Thumb.Template>
                                                                            </Thumb>
                                                                        </Grid>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>
                                                        </DockPanel>

                                                        <!-- ▲▼⧉× group buttons (collapsed only) -->
                                                        <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <Button Content="▲" Style="{StaticResource CbBtn}" Width="22" Padding="0"
                                                                    Command="{Binding MoveGroupUpCommand}"
                                                                    ToolTip="{DynamicResource Cap_Tip_MoveUp}"/>
                                                            <Button Content="▼" Style="{StaticResource CbBtn}" Width="22" Padding="0"
                                                                    Command="{Binding MoveGroupDownCommand}"
                                                                    ToolTip="{DynamicResource Cap_Tip_MoveDown}"/>
                                                            <Button Content="⧉" Style="{StaticResource CbBtn}" Width="22" Padding="0"
                                                                    Command="{Binding DuplicateGroupCommand}"
                                                                    ToolTip="{DynamicResource Cap_Tip_Duplicate}"/>
                                                            <Button Content="×" Style="{StaticResource CbBtn}" Width="22" Padding="0"
                                                                    Command="{Binding RemoveGroupCommand}"
                                                                    ToolTip="{DynamicResource CatBuilder_Tip_Delete}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Card list (DataContext still = CardGroupVm). Hidden when collapsed. -->
                                                <ListBox x:Name="CardsListBox"
                                                         ItemsSource="{Binding Cards}"
                                                         SelectedItem="{Binding SelectedCard, Mode=TwoWay}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                         VirtualizingStackPanel.IsVirtualizing="False">
                                                    <ListBox.Style>
                                                        <Style TargetType="ListBox">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListBox.Style>
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding"     Value="6,5"/>
                                                            <Setter Property="Background"  Value="Transparent"/>
                                                            <Setter Property="Foreground"  Value="{DynamicResource CheckupPrimaryText}"/>
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                            <Setter Property="BorderBrush"    Value="{DynamicResource CheckupSeparator}"/>
                                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                            <Setter Property="AllowDrop"       Value="True"/>
                                                            <EventSetter Event="DragEnter" Handler="Card_DragEnter"/>
                                                            <EventSetter Event="DragLeave" Handler="Card_DragLeave"/>
                                                            <EventSetter Event="Drop"      Handler="Card_Drop"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="4"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <!-- Colored group accent strip -->
                                                                            <Rectangle Grid.Column="0"
                                                                                       Fill="{Binding DataContext.AccentBrush,
                                                                                             RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                                                       IsHitTestVisible="False"/>
                                                                            <Border Grid.Column="1"
                                                                                    Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                                    Padding="{TemplateBinding Padding}">
                                                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                                            </Border>
                                                                        </Grid>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource CheckupSelectedCardBackground}"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <!-- DataContext = CardRowVm; commands bound via AncestorType=ListBox → CardGroupVm -->
                                                        <DataTemplate>
                                                            <DockPanel>
                                                                <!-- Left: card drag handle -->
                                                                <Border DockPanel.Dock="Left"
                                                                        Cursor="SizeAll"
                                                                        Background="Transparent"
                                                                        Margin="0,0,6,0"
                                                                        VerticalAlignment="Top"
                                                                        MouseMove="CardDragHandle_MouseMove"
                                                                        ToolTip="{DynamicResource Tip_DragReorder}">
                                                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                          Width="10" Height="14" Margin="0,4,0,0">
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="*"/>
                                                                            <RowDefinition Height="*"/>
                                                                            <RowDefinition Height="*"/>
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Ellipse Grid.Row="0" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                        <Ellipse Grid.Row="1" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                        <Ellipse Grid.Row="2" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                        <Ellipse Grid.Row="0" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                        <Ellipse Grid.Row="1" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                        <Ellipse Grid.Row="2" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                                                    </Grid>
                                                                </Border>
                                                                <!-- Right: per-card action buttons (▲▼⧉×) -->
                                                                <StackPanel DockPanel.Dock="Right"
                                                                            VerticalAlignment="Top"
                                                                            Margin="4,2,0,0">
                                                                    <Button Content="▲"
                                                                            Width="20" Height="20"
                                                                            MinWidth="20"
                                                                            Padding="0"
                                                                            Margin="0,0,0,2"
                                                                            Style="{StaticResource CbBtn}"
                                                                            Command="{Binding DataContext.MoveCardUpCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip="{DynamicResource Cap_Tip_MoveUp}"/>
                                                                    <Button Content="▼"
                                                                            Width="20" Height="20"
                                                                            MinWidth="20"
                                                                            Padding="0"
                                                                            Margin="0,0,0,2"
                                                                            Style="{StaticResource CbBtn}"
                                                                            Command="{Binding DataContext.MoveCardDownCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip="{DynamicResource Cap_Tip_MoveDown}"/>
                                                                    <Button Content="⧉"
                                                                            Width="20" Height="20"
                                                                            MinWidth="20"
                                                                            Padding="0"
                                                                            Margin="0,0,0,2"
                                                                            Style="{StaticResource CbBtn}"
                                                                            Command="{Binding DataContext.DuplicateCardCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip="{DynamicResource Cap_Tip_Duplicate}"/>
                                                                    <Button Content="×"
                                                                            FontSize="14"
                                                                            Width="20" Height="20"
                                                                            MinWidth="20"
                                                                            Padding="0"
                                                                            Style="{StaticResource CbBtn}"
                                                                            Command="{Binding DataContext.RemoveCardCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip="{DynamicResource CatBuilder_Card_Remove}"/>
                                                                </StackPanel>
                                                                <!-- Left: header row + display columns -->
                                                                <DockPanel LastChildFill="False">
                                                                    <!-- Type pill — declared first so Dock="Bottom" anchors to actual bottom of card -->
                                                                    <Border DockPanel.Dock="Bottom"
                                                                            HorizontalAlignment="Right"
                                                                            Background="{Binding CardTypeKey, Converter={StaticResource CardTypeToBrushConverter}}"
                                                                            CornerRadius="8"
                                                                            Padding="7,2"
                                                                            Margin="0,0,0,3">
                                                                        <TextBlock Text="{Binding TypeLabel}"
                                                                                   Foreground="White"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"/>
                                                                    </Border>
                                                                    <DockPanel DockPanel.Dock="Top">
                                                                        <!-- Enabled checkbox -->
                                                                        <CheckBox DockPanel.Dock="Left"
                                                                                  IsChecked="{Binding Enabled}"
                                                                                  VerticalAlignment="Center"
                                                                                  Margin="0,0,6,0"
                                                                                  ToolTip="{DynamicResource CatBuilder_Card_Enabled}"/>
                                                                        <!-- Catalog picker (Dropdown / Button / Search cards) -->
                                                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left"
                                                                                    Visibility="{Binding IsDropdownButtonSearch, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Cap_TargetCatalog}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"/>
                                                                            <ComboBox ItemsSource="{Binding DataContext.AvailableCatalogs,
                                                                                                  RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                                                      SelectedValue="{Binding CatalogId, Mode=TwoWay}"
                                                                                      SelectedValuePath="Id"
                                                                                      Width="140" Height="24"
                                                                                      Margin="0,0,10,0">
                                                                                <ComboBox.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <TextBlock Text="{Binding Name}"/>
                                                                                    </DataTemplate>
                                                                                </ComboBox.ItemTemplate>
                                                                            </ComboBox>
                                                                        </StackPanel>
                                                                        <!-- Search: search roles -->
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Visibility="{Binding IsSearch, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_SearchRoles}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"/>
                                                                            <TextBox Text="{Binding SearchRoles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Width="80" Height="24" Margin="0,0,10,0"
                                                                                     VerticalContentAlignment="Center" Padding="3,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_TextRole}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"/>
                                                                            <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                      SelectedItem="{Binding SecRole, Mode=TwoWay}"
                                                                                      Width="60" Height="24" Margin="0,0,10,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_TooltipRole}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"/>
                                                                            <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                      SelectedItem="{Binding TooltipRole, Mode=TwoWay}"
                                                                                      Width="60" Height="24"/>
                                                                        </StackPanel>
                                                                        <!-- Dropdown + Button: display role pickers -->
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Visibility="{Binding IsDropdownOrButton, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_TextRole}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"/>
                                                                            <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                      SelectedItem="{Binding SecRole, Mode=TwoWay}"
                                                                                      Width="60" Height="24" Margin="0,0,10,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_TooltipRole}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"/>
                                                                            <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                      SelectedItem="{Binding TooltipRole, Mode=TwoWay}"
                                                                                      Width="60" Height="24"/>
                                                                        </StackPanel>
                                                                        <!-- Sync: role picker -->
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Visibility="{Binding IsSync, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_Role}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"/>
                                                                            <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                      SelectedItem="{Binding CompanionRole, Mode=TwoWay}"
                                                                                      Width="60" Height="24" Margin="0,0,10,0"/>
                                                                        </StackPanel>
                                                                        <!-- Multi-Pick: primary sep, role + companion sep -->
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Visibility="{Binding IsMultiPick, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_PriSep}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_CatTokenSep}"/>
                                                                            <TextBox Text="{Binding PrimaryTokenSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Width="40" Height="24" Margin="0,0,10,0"
                                                                                     VerticalContentAlignment="Center" Padding="3,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_Role}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_OutputRole}"/>
                                                                            <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                      SelectedItem="{Binding CompanionRole, Mode=TwoWay}"
                                                                                      Width="60" Height="24" Margin="0,0,10,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_CompanionSep}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_CompanionCatTokenSep}"/>
                                                                            <TextBox Text="{Binding CompanionTokenSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Width="50" Height="24"
                                                                                     VerticalContentAlignment="Center" Padding="3,0"/>
                                                                        </StackPanel>
                                                                        <!-- Pair Transform: source sep, lookup role, output role, output sep -->
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Visibility="{Binding IsPairTransform, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_SrcSep}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_CatTokenSep}"/>
                                                                            <TextBox Text="{Binding SourceTokenSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Width="40" Height="24" Margin="0,0,10,0"
                                                                                     VerticalContentAlignment="Center" Padding="3,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_LookupRole}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_LookupRole}"/>
                                                                            <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                      SelectedItem="{Binding LookupRole, Mode=TwoWay}"
                                                                                      Width="60" Height="24" Margin="0,0,10,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_OutputRole}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_OutputRole}"/>
                                                                            <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                      SelectedItem="{Binding OutputRole, Mode=TwoWay}"
                                                                                      Width="60" Height="24" Margin="0,0,10,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_OutSep}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_CompanionOutSep}"/>
                                                                            <TextBox Text="{Binding OutputTokenSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Width="50" Height="24" Margin="0,0,10,0"
                                                                                     VerticalContentAlignment="Center" Padding="3,0"/>
                                                                        </StackPanel>
                                                                        <!-- Card companion field picker (Link / Sync / MultiPick / PairTransform) -->
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Visibility="{Binding HasCardFieldPicker, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_Companion}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_CompanionField}"/>
                                                                            <Grid MinWidth="180">
                                                                                <Button x:Name="CfPickerBtn"
                                                                                        Click="CardFieldPickerBtn_Click"
                                                                                        FontSize="11"
                                                                                        Background="{DynamicResource CheckupButtonBackground}"
                                                                                        Foreground="{DynamicResource CheckupPrimaryText}"
                                                                                        BorderBrush="{DynamicResource CheckupButtonBorder}"
                                                                                        Height="26"
                                                                                        Padding="4,0,2,0">
                                                                                    <Button.Template>
                                                                                        <ControlTemplate TargetType="Button">
                                                                                            <Border x:Name="bdr"
                                                                                                    Background="{TemplateBinding Background}"
                                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                                    BorderThickness="1">
                                                                                                <Grid>
                                                                                                    <Grid.ColumnDefinitions>
                                                                                                        <ColumnDefinition Width="*"/>
                                                                                                        <ColumnDefinition Width="16"/>
                                                                                                    </Grid.ColumnDefinitions>
                                                                                                    <TextBlock Grid.Column="0"
                                                                                                               Text="{Binding CardFieldPickerDropText}"
                                                                                                               FontSize="11"
                                                                                                               Padding="4,0,2,0"
                                                                                                               VerticalAlignment="Center"
                                                                                                               TextTrimming="CharacterEllipsis"/>
                                                                                                    <Path Grid.Column="1"
                                                                                                          IsHitTestVisible="False"
                                                                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                                          Data="M 0 0 L 3.5 4 L 7 0 Z"
                                                                                                          Fill="{DynamicResource CheckupSecondaryText}"/>
                                                                                                </Grid>
                                                                                            </Border>
                                                                                            <ControlTemplate.Triggers>
                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                    <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource CheckupDragHighlight}"/>
                                                                                                </Trigger>
                                                                                            </ControlTemplate.Triggers>
                                                                                        </ControlTemplate>
                                                                                    </Button.Template>
                                                                                </Button>
                                                                                <Popup PlacementTarget="{Binding ElementName=CfPickerBtn}"
                                                                                       Placement="Bottom"
                                                                                       IsOpen="{Binding IsCardFieldPickerOpen, Mode=TwoWay}"
                                                                                       StaysOpen="False"
                                                                                       AllowsTransparency="True"
                                                                                       Opened="CardFieldPickerPopup_Opened"
                                                                                       Closed="CardFieldPickerPopup_Closed">
                                                                                    <Border MinWidth="150" MinHeight="80"
                                                                                            Background="{DynamicResource CheckupComboItemBackground}"
                                                                                            BorderBrush="{DynamicResource CheckupButtonBorder}"
                                                                                            BorderThickness="1">
                                                                                        <Grid>
                                                                                            <Grid.RowDefinitions>
                                                                                                <RowDefinition Height="Auto"/>
                                                                                                <RowDefinition Height="Auto"/>
                                                                                                <RowDefinition Height="Auto"/>
                                                                                                <RowDefinition Height="Auto"/>
                                                                                                <RowDefinition Height="*"/>
                                                                                                <RowDefinition Height="Auto"/>
                                                                                            </Grid.RowDefinitions>
                                                                                            <!-- Zone 1: Search box -->
                                                                                            <TextBox Grid.Row="0"
                                                                                                     Text="{Binding CardFieldPickerFilter, UpdateSourceTrigger=PropertyChanged}"
                                                                                                     Margin="4,4,4,2" Padding="4,3" FontSize="11" Height="26"
                                                                                                     TextWrapping="NoWrap" VerticalAlignment="Top" BorderThickness="1">
                                                                                                <TextBox.Style>
                                                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                                                        <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
                                                                                                    </Style>
                                                                                                </TextBox.Style>
                                                                                            </TextBox>
                                                                                            <!-- Separator before Favoriten -->
                                                                                            <Separator Grid.Row="1" Margin="4,0" Background="{DynamicResource CheckupButtonBorder}">
                                                                                                <Separator.Style>
                                                                                                    <Style TargetType="Separator">
                                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                        <Style.Triggers>
                                                                                                            <DataTrigger Binding="{Binding HasCardFieldPickerFavoriten}" Value="True">
                                                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                                            </DataTrigger>
                                                                                                        </Style.Triggers>
                                                                                                    </Style>
                                                                                                </Separator.Style>
                                                                                            </Separator>
                                                                                            <!-- Zone 3: Favoriten -->
                                                                                            <ItemsControl Grid.Row="2"
                                                                                                          ItemsSource="{Binding CardFieldPickerFavoriten}">
                                                                                                <ItemsControl.Style>
                                                                                                    <Style TargetType="ItemsControl">
                                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                        <Style.Triggers>
                                                                                                            <DataTrigger Binding="{Binding HasCardFieldPickerFavoriten}" Value="True">
                                                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                                                            </DataTrigger>
                                                                                                        </Style.Triggers>
                                                                                                    </Style>
                                                                                                </ItemsControl.Style>
                                                                                                <ItemsControl.ItemTemplate>
                                                                                                    <DataTemplate>
                                                                                                        <Border Background="Transparent"
                                                                                                                AllowDrop="True"
                                                                                                                DragEnter="CfFavoritenItem_DragEnter"
                                                                                                                Drop="CfFavoritenItem_Drop"
                                                                                                                MouseRightButtonUp="CardFieldPickerItem_RightClick"
                                                                                                                ToolTip="{DynamicResource FieldSel_PinTooltip}">
                                                                                                            <Border.Style>
                                                                                                                <Style TargetType="Border">
                                                                                                                    <Style.Triggers>
                                                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                                                            <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                                                                        </Trigger>
                                                                                                                    </Style.Triggers>
                                                                                                                </Style>
                                                                                                            </Border.Style>
                                                                                                            <Grid>
                                                                                                                <Grid.ColumnDefinitions>
                                                                                                                    <ColumnDefinition Width="18"/>
                                                                                                                    <ColumnDefinition Width="*"/>
                                                                                                                </Grid.ColumnDefinitions>
                                                                                                                <TextBlock Grid.Column="0"
                                                                                                                           Text="≡" FontSize="10"
                                                                                                                           Foreground="{DynamicResource CheckupDragHandleFill}"
                                                                                                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                                                                           Cursor="SizeNS"
                                                                                                                           MouseMove="CfFavoritenDragHandle_MouseMove"/>
                                                                                                                <Button Grid.Column="1"
                                                                                                                        Click="CardFieldPickerPinnedItem_Click"
                                                                                                                        Cursor="Hand" Padding="0">
                                                                                                                    <Button.Template>
                                                                                                                        <ControlTemplate TargetType="Button">
                                                                                                                            <Border Background="Transparent">
                                                                                                                                <TextBlock x:Name="txt"
                                                                                                                                           Text="{Binding DropText}"
                                                                                                                                           FontSize="11"
                                                                                                                                           Foreground="{DynamicResource CheckupPrimaryText}"
                                                                                                                                           Padding="2,3,6,3"/>
                                                                                                                            </Border>
                                                                                                                            <ControlTemplate.Triggers>
                                                                                                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                                                                                    <Setter TargetName="txt" Property="TextDecorations" Value="Strikethrough"/>
                                                                                                                                    <Setter TargetName="txt" Property="Foreground" Value="{DynamicResource CheckupSecondaryText}"/>
                                                                                                                                </DataTrigger>
                                                                                                                            </ControlTemplate.Triggers>
                                                                                                                        </ControlTemplate>
                                                                                                                    </Button.Template>
                                                                                                                </Button>
                                                                                                            </Grid>
                                                                                                        </Border>
                                                                                                    </DataTemplate>
                                                                                                </ItemsControl.ItemTemplate>
                                                                                            </ItemsControl>
                                                                                            <!-- Separator before groups -->
                                                                                            <Separator Grid.Row="3" Margin="4,0"
                                                                                                       Background="{DynamicResource CheckupButtonBorder}"/>
                                                                                            <!-- Zone 4: Scrollable collapsible groups -->
                                                                                            <ScrollViewer Grid.Row="4"
                                                                                                          VerticalScrollBarVisibility="Auto"
                                                                                                          CanContentScroll="False">
                                                                                                <ItemsControl ItemsSource="{Binding CardFieldPickerGroups}">
                                                                                                    <ItemsControl.ItemTemplate>
                                                                                                        <DataTemplate>
                                                                                                            <StackPanel>
                                                                                                                <Button Click="CardFieldPickerGroupHeader_Click"
                                                                                                                        HorizontalContentAlignment="Left"
                                                                                                                        Padding="0"
                                                                                                                        IsEnabled="{Binding IsChevronEnabled}">
                                                                                                                    <Button.Template>
                                                                                                                        <ControlTemplate TargetType="Button">
                                                                                                                            <Border Background="{DynamicResource CheckupGroupHeaderBackground}">
                                                                                                                                <Grid>
                                                                                                                                    <Grid.ColumnDefinitions>
                                                                                                                                        <ColumnDefinition Width="16"/>
                                                                                                                                        <ColumnDefinition Width="*"/>
                                                                                                                                    </Grid.ColumnDefinitions>
                                                                                                                                    <TextBlock Grid.Column="0"
                                                                                                                                               x:Name="chevron" Text="▶" FontSize="8"
                                                                                                                                               Foreground="{DynamicResource CheckupGroupHeaderForeground}"
                                                                                                                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                                                                                                    <TextBlock Grid.Column="1"
                                                                                                                                               Text="{Binding GroupDisplayName}"
                                                                                                                                               FontSize="10" FontWeight="Bold"
                                                                                                                                               Foreground="{DynamicResource CheckupGroupHeaderForeground}"
                                                                                                                                               Padding="2,2,6,2"/>
                                                                                                                                </Grid>
                                                                                                                            </Border>
                                                                                                                            <ControlTemplate.Triggers>
                                                                                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                                                                    <Setter TargetName="chevron" Property="Text" Value="▼"/>
                                                                                                                                </DataTrigger>
                                                                                                                                <Trigger Property="IsEnabled" Value="False">
                                                                                                                                    <Setter TargetName="chevron" Property="Visibility" Value="Collapsed"/>
                                                                                                                                </Trigger>
                                                                                                                            </ControlTemplate.Triggers>
                                                                                                                        </ControlTemplate>
                                                                                                                    </Button.Template>
                                                                                                                </Button>
                                                                                                                <ItemsControl ItemsSource="{Binding FilteredItems}" AlternationCount="2">
                                                                                                                    <ItemsControl.Style>
                                                                                                                        <Style TargetType="ItemsControl">
                                                                                                                            <Style.Triggers>
                                                                                                                                <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                                                </DataTrigger>
                                                                                                                            </Style.Triggers>
                                                                                                                        </Style>
                                                                                                                    </ItemsControl.Style>
                                                                                                                    <ItemsControl.ItemTemplate>
                                                                                                                        <DataTemplate>
                                                                                                                            <Grid>
                                                                                                                                <Border x:Name="rowBg" Background="{DynamicResource CheckupRowBackground0}"/>
                                                                                                                                <Button Click="CardFieldPickerItem_Click"
                                                                                                                                        MouseRightButtonUp="CardFieldPickerItem_RightClick"
                                                                                                                                        HorizontalContentAlignment="Left"
                                                                                                                                        Padding="0" Cursor="Hand"
                                                                                                                                        ToolTip="{DynamicResource FieldSel_PinTooltip}">
                                                                                                                                    <Button.Template>
                                                                                                                                        <ControlTemplate TargetType="Button">
                                                                                                                                            <Border x:Name="bdr" Background="Transparent">
                                                                                                                                                <DockPanel LastChildFill="True">
                                                                                                                                                    <Rectangle DockPanel.Dock="Bottom"
                                                                                                                                                               Height="1"
                                                                                                                                                               Stroke="{DynamicResource CheckupSeparator}"
                                                                                                                                                               StrokeThickness="1"
                                                                                                                                                               StrokeDashArray="1 2"
                                                                                                                                                               SnapsToDevicePixels="True"/>
                                                                                                                                                    <TextBlock Text="{Binding DropText}"
                                                                                                                                                               FontSize="11"
                                                                                                                                                               Foreground="{DynamicResource CheckupPrimaryText}"
                                                                                                                                                               Padding="14,3,6,2"/>
                                                                                                                                                </DockPanel>
                                                                                                                                            </Border>
                                                                                                                                            <ControlTemplate.Triggers>
                                                                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                                                                    <Setter TargetName="bdr" Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                                                                                                </Trigger>
                                                                                                                                            </ControlTemplate.Triggers>
                                                                                                                                        </ControlTemplate>
                                                                                                                                    </Button.Template>
                                                                                                                                </Button>
                                                                                                                            </Grid>
                                                                                                                            <DataTemplate.Triggers>
                                                                                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                                                                                                                                    <Setter TargetName="rowBg" Property="Background" Value="{DynamicResource CheckupRowBackground1}"/>
                                                                                                                                </DataTrigger>
                                                                                                                            </DataTemplate.Triggers>
                                                                                                                        </DataTemplate>
                                                                                                                    </ItemsControl.ItemTemplate>
                                                                                                                </ItemsControl>
                                                                                                            </StackPanel>
                                                                                                        </DataTemplate>
                                                                                                    </ItemsControl.ItemTemplate>
                                                                                                </ItemsControl>
                                                                                            </ScrollViewer>
                                                                                            <!-- Resize grip (height only) -->
                                                                                            <Thumb Grid.Row="5"
                                                                                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                                                   Width="12" Height="12" Cursor="SizeNS"
                                                                                                   DragDelta="CardFieldResizeThumb_DragDelta">
                                                                                                <Thumb.Template>
                                                                                                    <ControlTemplate TargetType="Thumb">
                                                                                                        <Path Data="M 0 12 L 12 0 M 4 12 L 12 4 M 8 12 L 12 8"
                                                                                                              Stroke="{DynamicResource CheckupSecondaryText}"
                                                                                                              StrokeThickness="1.5"/>
                                                                                                    </ControlTemplate>
                                                                                                </Thumb.Template>
                                                                                            </Thumb>
                                                                                        </Grid>
                                                                                    </Border>
                                                                                </Popup>
                                                                            </Grid>
                                                                        </StackPanel>
                                                                        <!-- PrefixSuffix: prefix, suffix, remove mode -->
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Visibility="{Binding IsPrefixSuffix, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_Prefix}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_PsPrefix}"/>
                                                                            <TextBox Text="{Binding PsPrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Width="80" Height="24" Margin="0,0,10,0"
                                                                                     VerticalContentAlignment="Center" Padding="3,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_Suffix}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_PsSuffix}"/>
                                                                            <TextBox Text="{Binding PsSuffix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Width="80" Height="24" Margin="0,0,10,0"
                                                                                     VerticalContentAlignment="Center" Padding="3,0"/>
                                                                            <CheckBox Content="{DynamicResource CatBuilder_Card_PsRemove}"
                                                                                      IsChecked="{Binding PsIsRemoveMode, Mode=TwoWay}"
                                                                                      VerticalAlignment="Center"
                                                                                      ToolTip="{DynamicResource Tip_PsRemoveMode}"/>
                                                                        </StackPanel>
                                                                        <!-- Basic Logic: formula expression + optional target field override -->
                                                                        <StackPanel Visibility="{Binding IsBasicLogic, Converter={StaticResource BoolToVis}}">
                                                                            <DockPanel Margin="0,0,0,4">
                                                                                <TextBlock DockPanel.Dock="Left"
                                                                                           Text="{DynamicResource CatBuilder_Card_Formula}"
                                                                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                                                                           Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                           ToolTip="{DynamicResource Tip_FormulaText}"/>
                                                                                <TextBox Text="{Binding FormulaText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                         AcceptsReturn="False"
                                                                                         VerticalContentAlignment="Center"
                                                                                         Padding="3,0"
                                                                                         Height="24"
                                                                                         FontFamily="Consolas, Courier New, monospace"
                                                                                         HorizontalAlignment="Stretch"/>
                                                                            </DockPanel>
                                                                            <DockPanel>
                                                                                <TextBlock DockPanel.Dock="Left"
                                                                                           Text="{DynamicResource CatBuilder_Card_FormulaTarget}"
                                                                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                                                                           Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                           ToolTip="{DynamicResource Tip_FormulaTarget}"/>
                                                                                <ComboBox ItemsSource="{Binding AvailableTargetFields}"
                                                                                          SelectedValue="{Binding FormulaTargetFieldKey, Mode=TwoWay}"
                                                                                          SelectedValuePath="Key"
                                                                                          DisplayMemberPath="Label"
                                                                                          Height="24"
                                                                                          HorizontalAlignment="Stretch"/>
                                                                            </DockPanel>
                                                                        </StackPanel>
                                                                        <!-- Sort: lookup role, token sep, invert -->
                                                                        <StackPanel Orientation="Horizontal"
                                                                                    Visibility="{Binding IsSort, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_SrtLookup}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_SrtLookupRole}"/>
                                                                            <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                      SelectedItem="{Binding SrtLookupRole, Mode=TwoWay}"
                                                                                      Width="60" Height="24" Margin="0,0,10,0"/>
                                                                            <TextBlock Text="{DynamicResource CatBuilder_Card_SrcSep}"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Foreground="{DynamicResource CheckupSecondaryText}"
                                                                                       ToolTip="{DynamicResource Tip_CatTokenSep}"/>
                                                                            <TextBox Text="{Binding SrtTokenSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Width="40" Height="24" Margin="0,0,10,0"
                                                                                     VerticalContentAlignment="Center" Padding="3,0"/>
                                                                            <CheckBox Content="{DynamicResource CatBuilder_Card_SrtInvert}"
                                                                                      IsChecked="{Binding SrtIsInvert, Mode=TwoWay}"
                                                                                      VerticalAlignment="Center"
                                                                                      ToolTip="{DynamicResource Tip_SrtInvert}"/>
                                                                        </StackPanel>
                                                                    </DockPanel>
                                                                    <!-- Display columns (Dropdown / Button / Search) -->
                                                                    <TextBlock DockPanel.Dock="Top"
                                                                               Text="{DynamicResource CatBuilder_Card_DisplaySection}"
                                                                               Margin="90,6,0,2" FontSize="10"
                                                                               Foreground="{DynamicResource CheckupSecondaryText}"
                                                                               Visibility="{Binding IsDropdownButtonSearch, Converter={StaticResource BoolToVis}}"/>
                                                                    <ItemsControl DockPanel.Dock="Top"
                                                                                  ItemsSource="{Binding DisplayColumnVms}"
                                                                                  Margin="90,0,0,2"
                                                                                  Visibility="{Binding IsDropdownButtonSearch, Converter={StaticResource BoolToVis}}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <WrapPanel Orientation="Horizontal"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <ComboBox ItemsSource="{Binding AvailableCatalogRoles}"
                                                                                          SelectedItem="{Binding Role, Mode=TwoWay}"
                                                                                          Width="60" Height="24" Margin="0,2,6,0"/>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </DockPanel>
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                            </StackPanel>
                                            </Grid>
                                        </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                        <!-- Bottom section (Cards panel + toolbar) -->
                        <StackPanel Grid.Row="2">
                        <!-- Row 1 — collapsible card-type buttons (folds UP: appears above strip) -->
                        <Border Background="{DynamicResource CheckupGroupHeaderBackground}"
                                BorderBrush="{DynamicResource CheckupSeparator}"
                                BorderThickness="0,1,0,0"
                                Padding="8,6"
                                Visibility="{Binding IsCardPanelOpen, Converter={StaticResource BoolToVis}}">
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource CatBuilder_Card_AddButton}"
                                        Command="{Binding AddButtonToActiveCommand}"
                                        Style="{StaticResource CbBtn}"/>
                                <Button Content="{DynamicResource CatBuilder_Card_AddDropdown}"
                                        Command="{Binding AddDropdownToActiveCommand}"
                                        Style="{StaticResource CbBtn}"/>
                                <Button Content="{DynamicResource CatBuilder_Card_AddLink}"
                                        Command="{Binding AddLinkToActiveCommand}"
                                        Style="{StaticResource CbBtn}"/>
                                <Button Content="{DynamicResource CatBuilder_Card_AddPairTransform}"
                                        Command="{Binding AddPairTransformToActiveCommand}"
                                        Style="{StaticResource CbBtn}"/>
                                <Button Content="{DynamicResource CatBuilder_Card_AddPrefixSuffix}"
                                        Command="{Binding AddPrefixSuffixToActiveCommand}"
                                        Style="{StaticResource CbBtn}"/>
                                <Button Content="{DynamicResource CatBuilder_Card_AddSort}"
                                        Command="{Binding AddSortToActiveCommand}"
                                        Style="{StaticResource CbBtn}"/>
                                <Button Content="{DynamicResource CatBuilder_Card_AddSearch}"
                                        Command="{Binding AddSearchToActiveCommand}"
                                        Style="{StaticResource CbBtn}"/>
                                <Button Content="{DynamicResource CatBuilder_Card_AddMultiPick}"
                                        Command="{Binding AddMultiPickToActiveCommand}"
                                        Style="{StaticResource CbBtn}"/>
                                <Button Content="{DynamicResource CatBuilder_Card_AddSync}"
                                        Command="{Binding AddSyncToActiveCommand}"
                                        Style="{StaticResource CbBtn}"/>
                            </WrapPanel>
                        </Border>
                        <!-- Row 2 — full-width toggle strip, label centered, arrow right -->
                        <Button Command="{Binding ToggleCardPanelCommand}"
                                Style="{StaticResource CardToggleStrip}"
                                ToolTip="{DynamicResource Cap_Tip_ToggleCardPanel}">
                            <Grid>
                                <!-- Centered label -->
                                <TextBlock Text="{DynamicResource CatBuilder_Panel_Cards}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource CheckupSecondaryText}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <!-- Chevron anchored to right edge — matches Basic Logics Path style -->
                                <Path x:Name="CardPanelChevron"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0"
                                      Data="M 0 5 L 5 0 L 10 5"
                                      Stroke="{DynamicResource CheckupSecondaryText}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="M 0 5 L 5 0 L 10 5"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCardPanelOpen}" Value="True">
                                                    <Setter Property="Data" Value="M 0 0 L 5 5 L 10 0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                        </Button>
                        <!-- Row 3 — always visible: + Add Group | ℹ ▲▼⧉× -->
                        <Border Background="{DynamicResource CheckupGroupHeaderBackground}"
                                BorderBrush="{DynamicResource CheckupSeparator}"
                                BorderThickness="0,1,0,0"
                                Padding="8,5">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="ℹ"
                                            Click="CapCardHelp_Click"
                                            Style="{StaticResource CbBtn}"
                                            IsEnabled="True"
                                            Width="26" Padding="0"
                                            ToolTip="{DynamicResource Cap_Tip_CardHelp}"/>
                                    <Button Content="▲"
                                            Command="{Binding MoveActiveUpCommand}"
                                            Style="{StaticResource CbBtn}"
                                            ToolTip="{DynamicResource Cap_Tip_MoveUp}"
                                            Width="26" Padding="0"/>
                                    <Button Content="▼"
                                            Command="{Binding MoveActiveDownCommand}"
                                            Style="{StaticResource CbBtn}"
                                            ToolTip="{DynamicResource Cap_Tip_MoveDown}"
                                            Width="26" Padding="0"/>
                                    <Button Content="⧉"
                                            Command="{Binding DuplicateActiveCommand}"
                                            Style="{StaticResource CbBtn}"
                                            ToolTip="{DynamicResource Cap_Tip_Duplicate}"
                                            Width="26" Padding="0"/>
                                    <Button Content="×"
                                            Command="{Binding RemoveActiveCommand}"
                                            Style="{StaticResource CbBtn}"
                                            ToolTip="{DynamicResource Cap_Tip_Remove}"
                                            Width="26" Padding="0" Margin="0"/>
                                </StackPanel>
                                <Button Content="{DynamicResource CatBuilder_Btn_AddGroup}"
                                        Command="{Binding AddGroupCommand}"
                                        Style="{StaticResource CbBtn}"
                                        VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                    </StackPanel>

                        <!-- Lock overlay — scoped to the groups editing area (Row 1) only.
                             Card parameter editors there are TwoWay-bound (not command-gated),
                             so they need the transparent hit-test overlay. The bottom toolbar,
                             Cards palette and Basic Logics buttons are RelayCommands gated by
                             IsSelectedCapSetEditable / HasEditableActiveGroup, so they disable
                             themselves when locked and the ℹ Card-Help button stays clickable. -->
                        <Grid Grid.Row="1"
                              Background="Transparent"
                              Panel.ZIndex="100"
                              PreviewMouseWheel="LockOverlay_PreviewMouseWheel"
                              Visibility="{Binding IsSelectedCapSetLocked, Converter={StaticResource BoolToVis}}"/>
                    </Grid>

                    <!-- Basic Logics panel — toggle strip always visible, content expands to the right
                         extending the window width. Column 1 of the outer Grid spans full height. -->
                    <Expander x:Name="BLExpander"
                              Grid.Column="1"
                              IsExpanded="{Binding IsBasicLogicsPanelOpen, Mode=TwoWay}"
                              Style="{StaticResource BasicLogicsExpander}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{DynamicResource Cap_BasicLogicsTitle}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource CheckupPrimaryText}"
                                       Margin="0,0,0,8"/>
                            <!-- WrapPanel: buttons flow into a second column when panel height is too small. -->
                            <WrapPanel Orientation="Vertical"
                                       MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Expander}}">
                                <Button Content="{DynamicResource BasicLogic_Concatenate}"
                                        Command="{Binding DataContext.AddConcatenateToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Concatenate}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_IfElse}"
                                        Command="{Binding DataContext.AddIfElseToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_IfElse}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Lookup}"
                                        Command="{Binding DataContext.AddLookupToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Lookup}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Format}"
                                        Command="{Binding DataContext.AddFormatToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Format}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Round}"
                                        Command="{Binding DataContext.AddRoundToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Round}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Value}"
                                        Command="{Binding DataContext.AddValueToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Value}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Str}"
                                        Command="{Binding DataContext.AddStrToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Str}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Eq}"
                                        Command="{Binding DataContext.AddEqToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Eq}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Ne}"
                                        Command="{Binding DataContext.AddNeToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Ne}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Lt}"
                                        Command="{Binding DataContext.AddLtToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Lt}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Gt}"
                                        Command="{Binding DataContext.AddGtToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Gt}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Lte}"
                                        Command="{Binding DataContext.AddLteToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Lte}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Gte}"
                                        Command="{Binding DataContext.AddGteToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Gte}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_And}"
                                        Command="{Binding DataContext.AddAndToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_And}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Or}"
                                        Command="{Binding DataContext.AddOrToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Or}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Not}"
                                        Command="{Binding DataContext.AddNotToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Not}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Join}"
                                        Command="{Binding DataContext.AddJoinToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Join}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Left}"
                                        Command="{Binding DataContext.AddLeftToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Left}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Right}"
                                        Command="{Binding DataContext.AddRightToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Right}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Mid}"
                                        Command="{Binding DataContext.AddMidToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Mid}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Trim}"
                                        Command="{Binding DataContext.AddTrimToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Trim}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Upper}"
                                        Command="{Binding DataContext.AddUpperToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Upper}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Lower}"
                                        Command="{Binding DataContext.AddLowerToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Lower}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Replace}"
                                        Command="{Binding DataContext.AddReplaceToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Replace}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Abs}"
                                        Command="{Binding DataContext.AddAbsToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Abs}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Len}"
                                        Command="{Binding DataContext.AddLenToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Len}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Contains}"
                                        Command="{Binding DataContext.AddContainsToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Contains}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_StartsWith}"
                                        Command="{Binding DataContext.AddStartsWithToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_StartsWith}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_EndsWith}"
                                        Command="{Binding DataContext.AddEndsWithToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_EndsWith}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_IsEmpty}"
                                        Command="{Binding DataContext.AddIsEmptyToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_IsEmpty}"
                                        Style="{StaticResource CbBtn}" Margin="0,0,0,4" HorizontalAlignment="Stretch"/>
                                <Button Content="{DynamicResource BasicLogic_Default}"
                                        Command="{Binding DataContext.AddDefaultToActiveCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        ToolTip="{DynamicResource Tip_BasicLogic_Default}"
                                        Style="{StaticResource CbBtn}" Margin="0" HorizontalAlignment="Stretch"/>
                            </WrapPanel>
                        </DockPanel>
                    </Expander>

                </Grid>
            </Grid>

            <!-- Entry DataGrid — columns rebuilt dynamically by code-behind -->
            <DataGrid x:Name="EntryGrid"
                      IsReadOnly="{Binding IsSelectedCatalogLocked}"
                      Visibility="{Binding IsCatalogsTab, Converter={StaticResource BoolToVis}}"
                      Grid.Row="1"
                      ItemsSource="{Binding EntryRows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="True"
                      CanUserSortColumns="False"
                      SelectionUnit="Cell"
                      AlternationCount="2"
                      Background="{DynamicResource CheckupWindowBackground}"
                      Foreground="{DynamicResource CheckupPrimaryText}"
                      BorderBrush="{DynamicResource CheckupSeparator}"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource CheckupSeparator}"
                      ColumnHeaderHeight="40"
                      RowHeight="26"
                      SelectionMode="Extended"
                      HeadersVisibility="All"
                      RowHeaderWidth="36"
                      LoadingRow="EntryGrid_LoadingRow"
                      SelectedCellsChanged="EntryGrid_SelectedCellsChanged"
                      ColumnDisplayIndexChanged="EntryGrid_ColumnDisplayIndexChanged"
                      PreviewKeyDown="EntryGrid_PreviewKeyDown"
                      HorizontalScrollBarVisibility="Visible"
                      VerticalScrollBarVisibility="Auto"/>

            <!-- Bottom action bar — row ops | column ops | dirty indicator + save (catalogs tab only) -->
            <Border Grid.Row="2"
                    Background="{DynamicResource CheckupGroupHeaderBackground}"
                    BorderBrush="{DynamicResource CheckupSeparator}"
                    BorderThickness="0,1,0,0"
                    Padding="8,6"
                    Visibility="{Binding IsCatalogsTab, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <!-- Right: dirty indicator + save -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource CatBuilder_UnsavedIndicator}"
                                   Foreground="#FF6B6B"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="{DynamicResource CatBuilder_Btn_Save}"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource CbBtn}"
                                ToolTip="{DynamicResource CatBuilder_Tip_Save}"
                                Margin="0"/>
                    </StackPanel>
                    <!-- Left: row ops | column ops -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="{DynamicResource CatBuilder_Btn_AddRow}"
                                Click="AddRow_Click"
                                IsEnabled="{Binding IsSelectedCatalogEditable}"
                                Style="{StaticResource CbBtn}"/>
                        <Button Content="{DynamicResource CatBuilder_Btn_RemoveRow}"
                                Click="RemoveRow_Click"
                                IsEnabled="{Binding IsSelectedCatalogEditable}"
                                Style="{StaticResource CbBtn}"
                                Margin="0,0,8,0"/>
                        <Border Width="1" Margin="0,2,8,2"
                                Background="{DynamicResource CheckupSeparator}"/>
                        <Button Content="{DynamicResource CatBuilder_Btn_AddColumn}"
                                Click="AddColumn_Click"
                                IsEnabled="{Binding IsSelectedCatalogEditable}"
                                Style="{StaticResource CbBtn}"/>
                        <Button Content="{DynamicResource CatBuilder_Btn_RemoveColumn}"
                                Click="RemoveColumn_Click"
                                IsEnabled="{Binding IsSelectedCatalogEditable}"
                                Style="{StaticResource CbBtn}"
                                ToolTip="{DynamicResource CatBuilder_Tip_DeleteColumn}"
                                Margin="0,0,8,0"/>
                        <Border Width="1" Margin="0,2,8,2"
                                Background="{DynamicResource CheckupSeparator}"/>
                        <TextBlock Text="{DynamicResource CatBuilder_Role}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"
                                   Foreground="{DynamicResource CheckupSecondaryText}"/>
                        <ComboBox ItemsSource="{Binding ColumnRoleItems}"
                                  SelectedValuePath="Role"
                                  SelectedValue="{Binding SelectedColumnRole}"
                                  IsEnabled="{Binding HasEditableSelectedColumn}"
                                  Width="165"
                                  Height="26"
                                  Background="{DynamicResource CheckupButtonBackground}"
                                  Foreground="{DynamicResource CheckupPrimaryText}"
                                  BorderBrush="{DynamicResource CheckupButtonBorder}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="{DynamicResource CheckupComboItemBackground}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
                                    <Setter Property="Padding"    Value="6,3"/>
                                    <Setter Property="ToolTip"    Value="{Binding Tooltip}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                        <Button Content="ℹ"
                                Click="CatalogRoleHelp_Click"
                                Style="{StaticResource CbBtn}"
                                IsEnabled="True"
                                Width="26"
                                Padding="0"
                                Margin="4,0,0,0"
                                ToolTip="{DynamicResource CatBuilder_Tip_RoleHelp}"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
