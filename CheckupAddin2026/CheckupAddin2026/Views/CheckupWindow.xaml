<Window x:Class="CheckupAddIn.Views.CheckupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CheckupAddIn.ViewModels"
        xmlns:conv="clr-namespace:CheckupAddIn.Converters"
        xmlns:helpers="clr-namespace:CheckupAddIn.Helpers"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:CheckupViewModel, IsDesignTimeCreatable=True}"
        Title="{DynamicResource Win_Title_Checkup}"
        Width="650" Height="900"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CheckupWindowBackground}"
        Foreground="{DynamicResource CheckupPrimaryText}"
        FontFamily="Segoe UI" FontSize="12"
        AllowDrop="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Designer preview: change filename to LightTheme.xaml to preview light mode.
                     At runtime ThemeLoader adds the correct theme on top of this, so this
                     entry is harmless — it just ensures the designer has all color keys. -->
                <ResourceDictionary Source="/CheckupAddIn;component/Resources/DarkTheme.xaml"/>
                <!-- Designer preview: change filename to Addin_Language_File_EN.xaml to preview English
                     (or any other language file you have created).
                     At runtime LanguageLoader.ApplyTo() merges the JSON-based dict on top,
                     so this entry has no effect at runtime. -->
                <ResourceDictionary Source="/CheckupAddIn;component/Resources/Languages/Addin_Language_File_DE.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:GroupNameConverter x:Key="GroupNameConverter"/>
        <conv:StringEqualityConverter x:Key="StringEqualityConverter"/>
        <!-- Passes the Window DataContext (VM) into Popup content whose visual tree is isolated. -->
        <helpers:BindingProxy x:Key="VmProxy" Data="{Binding}"/>

        <!-- Multi-column Logic Dropdown / Search popup content (U1) — shared by both popups.
             DataContext is the RowModel; bound to LogicDropdownColumns + LogicDropdownRowsView. -->
        <DataTemplate x:Key="LogicDropdownPopupContent">
            <Border Background="{DynamicResource CheckupComboBoxBackground}"
                    BorderBrush="{DynamicResource CheckupButtonBorder}"
                    BorderThickness="1"
                    MinWidth="{Binding LogicDropdownFieldWidth}">
                <DockPanel LastChildFill="True">
                    <!-- Column header row -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource CheckupGroupHeaderBackground}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource CheckupSeparator}">
                        <ItemsControl ItemsSource="{Binding LogicDropdownColumns}">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ItemsPresenter/>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="{Binding Width}">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="{DynamicResource CheckupGroupHeaderForeground}"
                                                   Padding="6,3"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <!-- Visible separator line (always) -->
                                        <Border HorizontalAlignment="Right" Width="1"
                                                Background="{DynamicResource CheckupSeparator}"/>
                                        <!-- Hit-test Thumb for drag + double-click auto-fit -->
                                        <Thumb HorizontalAlignment="Right"
                                               Width="6" Cursor="SizeWE"
                                               DragDelta="LogicDropdownColumnThumb_DragDelta"
                                               MouseDoubleClick="LogicDropdownColumnThumb_DoubleClick">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Rectangle Fill="Transparent"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                            <Thumb.Style>
                                                <Style TargetType="Thumb">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLastColumn}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Thumb.Style>
                                        </Thumb>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <!-- Resize handle at bottom (TDD §5.13 user-resizable height) -->
                    <Thumb DockPanel.Dock="Bottom"
                           Height="6"
                           Cursor="SizeNS"
                           HorizontalAlignment="Stretch"
                           DragDelta="LogicDropdownHeightThumb_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="{DynamicResource CheckupGroupHeaderBackground}"
                                        BorderThickness="0,1,0,0"
                                        BorderBrush="{DynamicResource CheckupSeparator}"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                    <!-- Item rows -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  MaxHeight="{Binding LogicDropdownPopupHeight}">
                        <ItemsControl ItemsSource="{Binding LogicDropdownRowsView}"
                                      AlternationCount="2">
                            <!-- Strip the default ItemsControl ScrollViewer; the outer ScrollViewer is the only one. -->
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ItemsPresenter/>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="LogicDropdownItem_Click"
                                            HorizontalContentAlignment="Stretch"
                                            BorderThickness="0" Padding="0"
                                            ToolTip="{Binding Item.AuxValue}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="{DynamicResource CheckupRowBackground0}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                                                        <Setter Property="Background" Value="{DynamicResource CheckupRowBackground1}"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <DockPanel LastChildFill="True">
                                            <!-- Dotted horizontal row separator per TDD §5.13 -->
                                            <Rectangle DockPanel.Dock="Bottom"
                                                       Height="1"
                                                       Stroke="{DynamicResource CheckupSeparator}"
                                                       StrokeThickness="1"
                                                       StrokeDashArray="1 2"
                                                       SnapsToDevicePixels="True"/>
                                            <ItemsControl ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="{Binding Column.Width}">
                                                            <TextBlock Text="{Binding Value}"
                                                                       Padding="6,3" FontSize="11"
                                                                       Foreground="{DynamicResource CheckupPrimaryText}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <Border HorizontalAlignment="Right" Width="1"
                                                                    Background="{DynamicResource CheckupSeparator}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </DockPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="GroupItem">
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock x:Name="ghdr"
                                                       Text="{Binding Name}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource CheckupGroupHeaderForeground}"
                                                       Background="{DynamicResource CheckupGroupHeaderBackground}"
                                                       Padding="6,2"/>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Name}" Value="">
                                                    <Setter TargetName="ghdr" Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- Implicit Button style: custom ControlTemplate so DynamicResource Background is honoured
             in dark mode (Aero2 chrome overrides Background on the default template). -->
        <Style TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              Focusable="False"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width"                    Value="24"/>
            <Setter Property="Height"                   Value="24"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="FontWeight"               Value="Bold"/>
            <Setter Property="Background"               Value="{DynamicResource CheckupButtonBackground}"/>
            <Setter Property="Foreground"               Value="{DynamicResource CheckupButtonForeground}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource CheckupButtonBorder}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Margin"                   Value="1,0"/>
            <Setter Property="Padding"                  Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
        </Style>

        <Style x:Key="BarBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height"       Value="30"/>
            <Setter Property="MinWidth"     Value="50"/>
            <Setter Property="Margin"       Value="3,2"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource CheckupButtonBorder}"/>
            <Setter Property="Foreground"   Value="{DynamicResource CheckupButtonForeground}"/>
            <Setter Property="Padding"      Value="10,2"/>
        </Style>

        <!-- Full ComboBox ControlTemplate — DynamicResource colors work in both themes.
             Needed because WPF Aero2 renders the closed header with Windows chrome brushes
             that ignore the Background property, making the header white in dark mode. -->
        <Style TargetType="ComboBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Visible header: background + selected-item text + arrow -->
                            <Border x:Name="HeaderBorder"
                                    Background="{DynamicResource CheckupButtonBackground}"
                                    BorderBrush="{DynamicResource CheckupButtonBorder}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Runtime: shows the selected item via ItemTemplate (DropText) -->
                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Margin="4,1,0,1"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      TextBlock.Foreground="{DynamicResource CheckupPrimaryText}"/>
                                    <!-- Fallback/SPEZI label: shown when no item selected, or when this is a SPECIAL: row.
                                         SpeziTag is only visible for SPECIAL: rows (shows red "S:" prefix). -->
                                    <Grid x:Name="FallbackLabelContainer"
                                          Grid.Column="0"
                                          Margin="4,1,0,1"
                                          VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SpeziTag"
                                                   Grid.Column="0"
                                                   Text="S: "
                                                   Foreground="{DynamicResource CheckupErrorText}"
                                                   FontWeight="SemiBold"
                                                   Visibility="Collapsed"/>
                                        <TextBlock x:Name="FallbackLabel"
                                                   Grid.Column="1"
                                                   Text="{Binding FieldLabel}"
                                                   Foreground="{DynamicResource CheckupSecondaryText}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                    <Path Grid.Column="1"
                                          IsHitTestVisible="False"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Data="M 0 0 L 3.5 4 L 7 0 Z"
                                          Fill="{DynamicResource CheckupSecondaryText}"/>
                                </Grid>
                            </Border>
                            <!-- Transparent full-area toggle button — receives all clicks -->
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Dropdown popup — Grid wrapper holds the item Border + resize Thumb -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   Focusable="False">
                                <Grid>
                                    <Border MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                            Background="{DynamicResource CheckupComboItemBackground}"
                                            BorderBrush="{DynamicResource CheckupButtonBorder}"
                                            BorderThickness="1">
                                        <ScrollViewer CanContentScroll="False">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                    <Thumb HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Width="12" Height="12" Cursor="SizeNWSE"
                                           DragDelta="FieldSelectorResizeThumb_DragDelta">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Path Data="M 0 12 L 12 0 M 4 12 L 12 4 M 8 12 L 12 8"
                                                      Stroke="{DynamicResource CheckupSecondaryText}"
                                                      StrokeThickness="1.5"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="HeaderBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="HeaderBorder" Property="BorderBrush"
                                        Value="{DynamicResource CheckupDragHighlight}"/>
                            </Trigger>
                            <!-- Show FieldLabel when no item is selected (empty row or field missing from catalog) -->
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectionBoxItem}" Value="{x:Null}">
                                <Setter TargetName="FallbackLabelContainer" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Field is set but not present in the current document: greyed out + struck-through italic label -->
                            <DataTrigger Binding="{Binding IsFieldMissing}" Value="True">
                                <Setter TargetName="FallbackLabel" Property="Foreground"       Value="{DynamicResource CheckupSecondaryText}"/>
                                <Setter TargetName="FallbackLabel" Property="TextDecorations"  Value="Strikethrough"/>
                                <Setter TargetName="FallbackLabel" Property="FontStyle"        Value="Italic"/>
                            </DataTrigger>
                            <!-- All SPECIAL: rows: hide regular item display; show "S:" prefixed label -->
                            <DataTrigger Binding="{Binding IsSpecialRow}" Value="True">
                                <Setter TargetName="ContentSite"            Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="FallbackLabelContainer" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SpeziTag"               Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Editable ComboBox for value-picker rows (AllowedValues non-empty).
             Separate named style so it does not override the field-selector implicit ComboBox style.
             PART_EditableTextBox is required by WPF for IsEditable=True binding.
             AllowsTransparency intentionally omitted on Popup (causes flip bug on some GPU drivers). -->
        <Style x:Key="ValueCombo" TargetType="ComboBox">
            <Setter Property="IsEditable"          Value="True"/>
            <Setter Property="StaysOpenOnEdit"     Value="True"/>
            <Setter Property="IsTextSearchEnabled" Value="True"/>
            <Setter Property="MaxDropDownHeight"   Value="200"/>
            <Setter Property="AlternationCount"     Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="HeaderBorder"
                                    Background="{DynamicResource CheckupComboItemBackground}"
                                    BorderBrush="{DynamicResource CheckupButtonBorder}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Grid.Column="0"
                                             Margin="2,1,0,1"
                                             VerticalContentAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource CheckupPrimaryText}"
                                             CaretBrush="{DynamicResource CheckupPrimaryText}"
                                             SelectionBrush="{DynamicResource CheckupDragHighlight}"/>
                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent">
                                                    <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Data="M 0 0 L 3.5 4 L 7 0 Z"
                                                          Fill="{DynamicResource CheckupSecondaryText}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   Focusable="False">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource CheckupComboItemBackground}"
                                        BorderBrush="{DynamicResource CheckupButtonBorder}"
                                        BorderThickness="1">
                                    <ScrollViewer CanContentScroll="False">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="HeaderBorder" Property="BorderBrush"
                                        Value="{DynamicResource CheckupDragHighlight}"/>
                            </Trigger>
                            <!-- Red border when value changed but not valid -->
                            <DataTrigger Binding="{Binding ShowValidationError}" Value="True">
                                <Setter TargetName="HeaderBorder" Property="BorderBrush"
                                        Value="{DynamicResource CheckupErrorText}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="{DynamicResource CheckupRowBackground0}"/>
                        <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Grid>
                                        <Border x:Name="bdr"
                                                Background="{TemplateBinding Background}"
                                                Padding="2,0">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                        <Rectangle Height="1" VerticalAlignment="Bottom"
                                                   Stroke="{DynamicResource CheckupSeparator}"
                                                   StrokeThickness="1"
                                                   StrokeDashArray="1 2"
                                                   SnapsToDevicePixels="True"/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter Property="Background" Value="{DynamicResource CheckupRowBackground1}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Cursor hint + theme-aware foreground on value TextBlock -->
        <Style x:Key="ValueTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Cursor"     Value="Arrow"/>
            <Setter Property="ToolTip"    Value="{x:Null}"/>
            <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsWritableField}" Value="True">
                    <Setter Property="Cursor"  Value="IBeam"/>
                    <Setter Property="ToolTip" Value="{DynamicResource Tip_ClickEdit}"/>
                </DataTrigger>
                <!-- Red brush signals either a fixed highlight (FlangeDistance) or a multi-select mismatch -->
                <DataTrigger Binding="{Binding ValueForeground}" Value="{x:Static Brushes.Red}">
                    <Setter Property="Foreground" Value="{DynamicResource CheckupErrorText}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="12" Grid.IsSharedSizeScope="True">

        <!-- TOP: Filename row — Grid so the button (Col 2) shares width with the field-selector
             column via SharedSizeGroup="FieldSel". Col 0 is the "File:" label, left-aligned so
             its left edge matches the drag-handle column in the rows below. -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" SharedSizeGroup="FieldSel"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{DynamicResource Lbl_File}" FontWeight="Bold"
                       Foreground="{DynamicResource CheckupLabelText}"
                       Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding FileName}" FontWeight="Bold"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            <Button Grid.Column="2" Style="{StaticResource BarBtn}"
                    Content="{DynamicResource Btn_CatalogBuilder}"
                    ToolTip="{DynamicResource Tip_CatalogBuilder}"
                    Background="{DynamicResource CheckupButtonBackground}"
                    Click="BtnCatalogBuilder_Click"/>
        </Grid>

        <!-- BOTTOM: Status + Buttons -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,6,0,0"
                   x:Name="BottomBar" SizeChanged="BottomBar_SizeChanged">
            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding StatusMessage}"
                       FontSize="11" FontStyle="Italic"
                       Foreground="{DynamicResource CheckupSecondaryText}"
                       Margin="0,0,0,6"/>
            <Separator DockPanel.Dock="Top" Margin="0,0,0,6"
                       Background="{DynamicResource CheckupSeparator}"/>

            <DockPanel LastChildFill="True">

                <!-- Left: Purge Styles -->
                <Button DockPanel.Dock="Left" Style="{StaticResource BarBtn}"
                        Content="{DynamicResource Btn_PurgeStyles}"
                        Background="{DynamicResource CheckupSpecialButtonBackground}"
                        Command="{Binding PurgeStylesCommand}"/>

                <!-- Right: Info / Reset / Close -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource BarBtn}" Content="{DynamicResource Btn_Info}"
                            Background="{DynamicResource CheckupButtonBackground}"
                            Command="{Binding InfoCommand}"
                            Width="32" Padding="0" FontSize="14"/>
                    <Button Style="{StaticResource BarBtn}" Content="{DynamicResource Btn_Reset}"
                            Background="{DynamicResource CheckupDestructiveButtonBackground}"
                            Command="{Binding ResetCommand}"/>
                    <Button Style="{StaticResource BarBtn}" Content="{DynamicResource Btn_Close}"
                            Background="{DynamicResource CheckupButtonBackground}"
                            Command="{Binding CloseCommand}"/>
                </StackPanel>

                <!-- Center: Preset buttons (right-click to save) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnPreset1" Style="{StaticResource BarBtn}"
                            Command="{Binding Preset1Command}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        BorderThickness="1" BorderBrush="Transparent"
                                        Background="{DynamicResource CheckupWindowBackground}"
                                        Padding="10,2" SnapsToDevicePixels="True">
                                    <TextBlock Text="{Binding Preset1Name}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource CheckupButtonForeground}"
                                               FontSize="11"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsPreset1Active}" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource CheckupPresetActiveBorder}"/>
                                        <Setter TargetName="border" Property="Background"  Value="{DynamicResource CheckupPresetActiveBackground}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Menu_SavePreset}"
                                          Tag="0" Click="SavePreset_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource Menu_ExportPreset}"    Tag="0" Click="ExportPreset_Click"/>
                                <MenuItem Header="{DynamicResource Menu_ExportAllPresets}" Click="ExportAllPresets_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource Menu_ImportPreset}"    Tag="0" Click="ImportPreset_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="BtnPreset2" Style="{StaticResource BarBtn}"
                            Command="{Binding Preset2Command}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        BorderThickness="1" BorderBrush="Transparent"
                                        Background="{DynamicResource CheckupWindowBackground}"
                                        Padding="10,2" SnapsToDevicePixels="True">
                                    <TextBlock Text="{Binding Preset2Name}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource CheckupButtonForeground}"
                                               FontSize="11"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsPreset2Active}" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource CheckupPresetActiveBorder}"/>
                                        <Setter TargetName="border" Property="Background"  Value="{DynamicResource CheckupPresetActiveBackground}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Menu_SavePreset}"
                                          Tag="1" Click="SavePreset_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource Menu_ExportPreset}"    Tag="1" Click="ExportPreset_Click"/>
                                <MenuItem Header="{DynamicResource Menu_ExportAllPresets}" Click="ExportAllPresets_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource Menu_ImportPreset}"    Tag="1" Click="ImportPreset_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button x:Name="BtnPreset3" Style="{StaticResource BarBtn}"
                            Command="{Binding Preset3Command}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        BorderThickness="1" BorderBrush="Transparent"
                                        Background="{DynamicResource CheckupWindowBackground}"
                                        Padding="10,2" SnapsToDevicePixels="True">
                                    <TextBlock Text="{Binding Preset3Name}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{DynamicResource CheckupButtonForeground}"
                                               FontSize="11"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsPreset3Active}" Value="True">
                                        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource CheckupPresetActiveBorder}"/>
                                        <Setter TargetName="border" Property="Background"  Value="{DynamicResource CheckupPresetActiveBackground}"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Menu_SavePreset}"
                                          Tag="2" Click="SavePreset_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource Menu_ExportPreset}"    Tag="2" Click="ExportPreset_Click"/>
                                <MenuItem Header="{DynamicResource Menu_ExportAllPresets}" Click="ExportAllPresets_Click"/>
                                <Separator/>
                                <MenuItem Header="{DynamicResource Menu_ImportPreset}"    Tag="2" Click="ImportPreset_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>

            </DockPanel>
        </DockPanel>

        <!-- CENTER: Dynamic rows -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Focusable="False">
            <ItemsControl ItemsSource="{Binding Rows}" x:Name="RowList" AlternationCount="2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"      Value="{DynamicResource CheckupRowBackground0}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Margin"          Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding (ItemsControl.AlternationIndex),
                                                     RelativeSource={RelativeSource AncestorType=ContentPresenter}}" Value="1">
                                            <Setter Property="Background" Value="{DynamicResource CheckupRowBackground1}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                            <Setter Property="BorderThickness" Value="0,2,0,0"/>
                                            <Setter Property="BorderBrush"     Value="{DynamicResource CheckupDragHighlight}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid MinHeight="28"
                                  AllowDrop="True"
                                  DragEnter="Row_DragEnter"
                                  DragLeave="Row_DragLeave"
                                  Drop="Row_Drop"
                                  Tag="{Binding}">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="1"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FieldSel"/>
                                </Grid.ColumnDefinitions>

                                <!-- Linked-pair stripe: 4px blue bar on the left edge (Link card) -->
                                <Rectangle Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="3"
                                           Width="4" HorizontalAlignment="Left"
                                           IsHitTestVisible="False"
                                           Fill="{DynamicResource CheckupLinkStripe}"
                                           Visibility="{Binding IsLinked, Converter={StaticResource BoolToVis}}"/>

                                <!-- Sync stripe: 4px amber bar on the left edge (Sync card).
                                     Shifts 4px right when both Link and Sync are active → dual-stripe. -->
                                <Rectangle Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="3"
                                           Width="4" HorizontalAlignment="Left"
                                           IsHitTestVisible="False"
                                           Fill="{DynamicResource CheckupSyncStripe}"
                                           Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Margin" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLinked}" Value="True">
                                                    <Setter Property="Margin" Value="4,0,0,0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>

                                <!-- Col 0: Drag handle -->
                                <Border Grid.Row="0" Grid.Column="0"
                                        Cursor="SizeAll"
                                        Background="Transparent"
                                        MouseMove="DragHandle_MouseMove"
                                        ToolTip="{DynamicResource Tip_DragReorder}">
                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
                                          Width="10" Height="14">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Row="0" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                        <Ellipse Grid.Row="1" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                        <Ellipse Grid.Row="2" Grid.Column="0" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                        <Ellipse Grid.Row="0" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                        <Ellipse Grid.Row="1" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                        <Ellipse Grid.Row="2" Grid.Column="1" Width="3" Height="3" Fill="{DynamicResource CheckupDragHandleFill}" Margin="1"/>
                                    </Grid>
                                </Border>

                                <!-- Col 1: Inner grid — value display left, picker button right -->
                                <Grid Grid.Row="0" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Sub-col 0+1: Display TextBlock (normal rows in display mode) -->
                                    <TextBlock Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="{Binding DisplayValue}"
                                               Background="Transparent"
                                               VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                               Margin="4,0,8,0"
                                               TextTrimming="CharacterEllipsis"
                                               MouseRightButtonUp="Value_RightClick"
                                               Style="{StaticResource ValueTextBlockStyle}"
                                               Visibility="{Binding IsNormalDisplayMode, Converter={StaticResource BoolToVis}}">
                                        <TextBlock.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding DataContext.StartInlineEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"/>
                                        </TextBlock.InputBindings>
                                    </TextBlock>

                                    <!-- Sub-col 0+1: Logic mismatch display — matched prefix normal, unmatched tail red -->
                                    <Border Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="Transparent"
                                            VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                            Margin="4,0,8,0"
                                            MouseRightButtonUp="Value_RightClick"
                                            Visibility="{Binding IsValueMismatchDisplayMode, Converter={StaticResource BoolToVis}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Cursor" Value="Arrow"/>
                                                <Setter Property="ToolTip" Value="{x:Null}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWritableField}" Value="True">
                                                        <Setter Property="Cursor"  Value="IBeam"/>
                                                        <Setter Property="ToolTip" Value="{DynamicResource Tip_ClickEdit}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding DataContext.StartInlineEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding MatchedPart}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding UnmatchedPart}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource CheckupErrorText}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Sub-col 0+1: Multi-token display (Logic rows with MultiPick/PairTransform card) -->
                                    <Border Grid.Column="0" Grid.ColumnSpan="2"
                                            Background="Transparent"
                                            HorizontalAlignment="Stretch"
                                            MinHeight="20"
                                            Margin="4,0,2,0"
                                            MouseRightButtonUp="Value_RightClick"
                                            Visibility="{Binding IsMultiTokenDisplayMode, Converter={StaticResource BoolToVis}}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Cursor" Value="Arrow"/>
                                                <Setter Property="ToolTip" Value="{x:Null}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWritableField}" Value="True">
                                                        <Setter Property="Cursor"  Value="IBeam"/>
                                                        <Setter Property="ToolTip" Value="{DynamicResource Tip_ClickEdit}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.InputBindings>
                                            <MouseBinding Gesture="LeftClick"
                                                          Command="{Binding DataContext.StartInlineEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <ItemsControl ItemsSource="{Binding MultiTokenSegments}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Token}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                            <Setter Property="Foreground"      Value="{DynamicResource CheckupErrorText}"/>
                                                                            <Setter Property="TextDecorations" Value="Underline"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Separator}"
                                                                   Foreground="{DynamicResource CheckupPrimaryText}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <!-- Sub-col 0+1: Edit TextBox (plain free-text / multi-token autocomplete) -->
                                    <Grid x:Name="PlainTextEditorPanel"
                                          Grid.Column="0" Grid.ColumnSpan="2"
                                          HorizontalAlignment="Stretch"
                                          Visibility="{Binding IsPlainTextEditMode, Converter={StaticResource BoolToVis}}">
                                        <TextBox x:Name="PlainEditBox"
                                                 Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center" HorizontalAlignment="Stretch"
                                                 Margin="4,1,8,1"
                                                 MouseRightButtonUp="Value_RightClick"
                                                 KeyDown="EditTextBox_KeyDown"
                                                 TextChanged="EditTextBox_TextChanged"
                                                 LostFocus="EditControl_LostFocus"
                                                 IsVisibleChanged="EditControl_IsVisibleChanged"/>

                                        <!-- Per-token autocomplete popup — bound to IsMultiTokenAutoCompleteOpen -->
                                        <Popup PlacementTarget="{Binding ElementName=PlainEditBox}"
                                               Placement="Bottom"
                                               IsOpen="{Binding IsMultiTokenAutoCompleteOpen}"
                                               StaysOpen="True"
                                               Focusable="False">
                                            <Border MinWidth="300"
                                                    Background="{DynamicResource CheckupComboItemBackground}"
                                                    BorderBrush="{DynamicResource CheckupButtonBorder}"
                                                    BorderThickness="1">
                                                <ScrollViewer MaxHeight="220"
                                                              VerticalScrollBarVisibility="Auto"
                                                              CanContentScroll="False"
                                                              Focusable="False">
                                                    <ItemsControl ItemsSource="{Binding AutoCompleteItems}"
                                                                  AlternationCount="2"
                                                                  Focusable="False">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Button HorizontalContentAlignment="Left"
                                                                        Padding="0"
                                                                        BorderThickness="0"
                                                                        Background="Transparent"
                                                                        Foreground="{DynamicResource CheckupPrimaryText}"
                                                                        Click="MultiTokenAutoCompleteItem_Click">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                                </Trigger>
                                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                                                                                    <Setter Property="Background" Value="{DynamicResource CheckupRowBackground1}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <DockPanel LastChildFill="True">
                                                                        <Rectangle DockPanel.Dock="Bottom"
                                                                                   Height="1"
                                                                                   Stroke="{DynamicResource CheckupSeparator}"
                                                                                   StrokeThickness="1"
                                                                                   StrokeDashArray="1 2"
                                                                                   SnapsToDevicePixels="True"/>
                                                                        <TextBlock Text="{Binding Label}"
                                                                                   Padding="8,3"/>
                                                                    </DockPanel>
                                                                </Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <!-- Sub-col 0+1: Halbzeug inline editor (editable ComboBox with catalog suggestions) -->
                                    <ComboBox Grid.Column="0" Grid.ColumnSpan="2"
                                              Style="{StaticResource ValueCombo}"
                                              IsEditable="True"
                                              ItemsSource="{Binding AllowedValues}"
                                              Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Stretch"
                                              Margin="4,1,8,1"
                                              MouseRightButtonUp="Value_RightClick"
                                              PreviewKeyDown="ValueCombo_PreviewKeyDown"
                                              LostFocus="EditControl_LostFocus"
                                              IsVisibleChanged="EditControl_IsVisibleChanged"
                                              Visibility="{Binding IsHalbzeugTextEditMode, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Sub-col 0+1: Value-picker with live filter (AllowedValues fields) -->
                                    <Grid x:Name="AllowedValuesPanel"
                                          Grid.Column="0" Grid.ColumnSpan="2"
                                          Margin="4,1,8,1"
                                          Visibility="{Binding IsComboEditMode, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 x:Name="AllowedValuesTextBox"
                                                 Text="{Binding EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center"
                                                 Padding="4,0"
                                                 Background="{DynamicResource CheckupEditableBackground}"
                                                 Foreground="{DynamicResource CheckupPrimaryText}"
                                                 BorderBrush="{DynamicResource CheckupButtonBorder}"
                                                 MouseRightButtonUp="Value_RightClick"
                                                 PreviewKeyDown="AllowedValuesTextBox_PreviewKeyDown"
                                                 TextChanged="AllowedValuesTextBox_TextChanged"
                                                 LostFocus="EditControl_LostFocus"
                                                 IsVisibleChanged="EditControl_IsVisibleChanged"/>
                                        <Button Grid.Column="1"
                                                Width="22"
                                                Padding="0"
                                                PreviewMouseDown="AllowedValuesArrowBtn_PreviewMouseDown"
                                                Click="AllowedValuesArrowBtn_Click"
                                                Background="{DynamicResource CheckupButtonBackground}"
                                                Foreground="{DynamicResource CheckupButtonForeground}"
                                                BorderBrush="{DynamicResource CheckupButtonBorder}">
                                            <Path Data="M 0 0 L 4 4 L 8 0"
                                                  Stroke="{DynamicResource CheckupSecondaryText}"
                                                  StrokeThickness="1.5" Fill="Transparent"
                                                  Stretch="None"/>
                                        </Button>
                                        <Popup PlacementTarget="{Binding ElementName=AllowedValuesPanel}"
                                               Placement="Bottom"
                                               IsOpen="{Binding IsAllowedValuesPopupOpen, Mode=TwoWay}"
                                               StaysOpen="False"
                                               AllowsTransparency="False"
                                               PopupAnimation="None">
                                            <Border Background="{DynamicResource CheckupComboBoxBackground}"
                                                    BorderBrush="{DynamicResource CheckupButtonBorder}"
                                                    BorderThickness="1"
                                                    MinWidth="{Binding ElementName=AllowedValuesPanel, Path=ActualWidth}">
                                                <ListBox ItemsSource="{Binding FilteredAllowedValues}"
                                                         SelectedItem="{Binding HighlightedAllowedValue, Mode=TwoWay}"
                                                         MaxHeight="200"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Focusable="False"
                                                         KeyboardNavigation.TabNavigation="None"
                                                         VirtualizingStackPanel.IsVirtualizing="True"
                                                         VirtualizingStackPanel.VirtualizationMode="Recycling">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding" Value="4,2"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
                                                            <Setter Property="Focusable" Value="False"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <Border x:Name="bdr"
                                                                                Background="{TemplateBinding Background}"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="bdr" Property="Background"
                                                                                        Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsSelected" Value="True">
                                                                                <Setter TargetName="bdr" Property="Background"
                                                                                        Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <EventSetter Event="MouseLeftButtonUp" Handler="AllowedValuesItem_Click"/>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"
                                                                       Foreground="{DynamicResource CheckupPrimaryText}"
                                                                       FontSize="11"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <!-- Sub-col 0+1: Multi-column Logic Dropdown popup (U1).
                                         Custom Grid+TextBox+Button+Popup. Popup contains an N-column grid
                                         (PRI / SEC / AUX / extras) with movable Thumbs between columns.
                                         Double-click on a Thumb auto-fits the column to its widest visible value.
                                         Column widths persisted via UiStateStore per catalog ID. -->
                                    <!-- Sub-col 0+1: Unified Logic panel.
                                         Arrow button is always visible when any Logic group is active.
                                         TextBox shows EditText (read-only display for Dropdown-only; editable for Search rows).
                                         Search card rows: TextChanged auto-opens popup and applies live filter.
                                         Dropdown card rows: arrow button opens popup manually. -->
                                    <Grid x:Name="LogicDropdownPanel"
                                          Grid.Column="0" Grid.ColumnSpan="2"
                                          Margin="4,1,8,1"
                                          Visibility="{Binding IsLogicComboEditMode, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 x:Name="LogicDropdownTextBox"
                                                 Text="{Binding EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Tag="{Binding ElementName=LogicDropdownPanel, Path=ActualWidth}"
                                                 VerticalContentAlignment="Center"
                                                 Padding="4,0"
                                                 Background="{DynamicResource CheckupEditableBackground}"
                                                 Foreground="{DynamicResource CheckupPrimaryText}"
                                                 BorderBrush="{DynamicResource CheckupButtonBorder}"
                                                 MouseRightButtonUp="Value_RightClick"
                                                 PreviewKeyDown="LogicDropdownTextBox_PreviewKeyDown"
                                                 TextChanged="LogicSearchTextBox_TextChanged"
                                                 LostFocus="EditControl_LostFocus"
                                                 IsVisibleChanged="EditControl_IsVisibleChanged"/>
                                        <Button Grid.Column="1"
                                                Width="22"
                                                Padding="0"
                                                Click="LogicDropdownArrowBtn_Click"
                                                PreviewMouseDown="LogicDropdownArrowBtn_PreviewMouseDown"
                                                Tag="{Binding ElementName=LogicDropdownPanel, Path=ActualWidth}"
                                                Background="{DynamicResource CheckupButtonBackground}"
                                                Foreground="{DynamicResource CheckupButtonForeground}"
                                                BorderBrush="{DynamicResource CheckupButtonBorder}">
                                            <Path Data="M 0 0 L 4 4 L 8 0"
                                                  Stroke="{DynamicResource CheckupSecondaryText}"
                                                  StrokeThickness="1.5" Fill="Transparent"
                                                  Stretch="None"/>
                                        </Button>
                                        <Popup PlacementTarget="{Binding ElementName=LogicDropdownPanel}"
                                               Placement="Custom"
                                               CustomPopupPlacementCallback="ForceLogicPopupBelow"
                                               IsOpen="{Binding IsLogicPopupOpen, Mode=TwoWay}"
                                               StaysOpen="False"
                                               AllowsTransparency="False"
                                               PopupAnimation="None">
                                            <ContentPresenter Content="{Binding}"
                                                              ContentTemplate="{StaticResource LogicDropdownPopupContent}"/>
                                        </Popup>
                                    </Grid>

                                    <!-- Sub-col 1: Logic catalog picker button (Logic rows with Button card in display mode) -->
                                    <Button Grid.Column="1"
                                            Content="{DynamicResource Btn_CatalogPicker}"
                                            ToolTip="{DynamicResource Tip_CatalogPicker}"
                                            FontSize="11"
                                            Background="{DynamicResource CheckupButtonBackground}"
                                            Foreground="{DynamicResource CheckupButtonForeground}"
                                            BorderBrush="{DynamicResource CheckupButtonBorder}"
                                            BorderThickness="1"
                                            Margin="2,1,2,1" Height="24"
                                            Click="CatalogPickerBtn_Click"
                                            Visibility="{Binding IsLogicPickerDisplayMode, Converter={StaticResource BoolToVis}}"/>
                                </Grid>

                                <!-- Col 2: Dropdown (normal mode) — split popup with sticky top zone -->
                                <Grid Grid.Row="0" Grid.Column="2"
                                      IsEnabled="{Binding DataContext.IsSingleSelection, RelativeSource={RelativeSource AncestorType=Window}}"
                                      Visibility="{Binding IsFieldSelectorVisible, Converter={StaticResource BoolToVis}}">

                                    <!-- Header button — shows current selection, toggles popup -->
                                    <Button x:Name="FieldSelectorBtn"
                                            Click="FieldSelectorBtn_Click"
                                            FontSize="11"
                                            Background="{DynamicResource CheckupButtonBackground}"
                                            Foreground="{DynamicResource CheckupPrimaryText}"
                                            BorderBrush="{DynamicResource CheckupButtonBorder}"
                                            BorderThickness="1"
                                            HorizontalContentAlignment="Left"
                                            VerticalContentAlignment="Center"
                                            Margin="2,1,2,1" Height="24"
                                            Padding="4,0,2,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Normal label: field exists and is not a Special row -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding SelectedField.DropText}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFieldMissing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSpecialRow}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- Fallback/Special label: shown when field is missing or is a Special row -->
                                            <Grid Grid.Column="0" VerticalAlignment="Center">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFieldMissing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsSpecialRow}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- S: prefix — only for Special rows -->
                                                <TextBlock Grid.Column="0"
                                                           Text="S: "
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource CheckupErrorText}"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSpecialRow}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Field label — greyed + strikethrough when missing -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding FieldLabel}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFieldMissing}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource CheckupSecondaryText}"/>
                                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <Path Grid.Column="1"
                                                  IsHitTestVisible="False"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Data="M 0 0 L 3.5 4 L 7 0 Z"
                                                  Fill="{DynamicResource CheckupSecondaryText}"/>
                                        </Grid>
                                    </Button>

                                    <!-- Custom field selector popup with fixed top zone + scrollable body -->
                                    <Popup x:Name="FieldSelectorPopup"
                                           PlacementTarget="{Binding ElementName=FieldSelectorBtn}"
                                           Placement="Bottom"
                                           IsOpen="{Binding IsFieldSelectorOpen, Mode=TwoWay}"
                                           StaysOpen="False"
                                           AllowsTransparency="True"
                                           Opened="FieldSelectorPopup_Opened"
                                           Closed="FieldSelectorPopup_Closed">
                                        <Border MinWidth="150" MinHeight="80"
                                                Background="{DynamicResource CheckupComboItemBackground}"
                                                BorderBrush="{DynamicResource CheckupButtonBorder}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>  <!-- Zone 1: Search -->
                                                    <RowDefinition Height="Auto"/>  <!-- Zone 2: Fixed actions -->
                                                    <RowDefinition Height="Auto"/>  <!-- Sep: before Favoriten -->
                                                    <RowDefinition Height="Auto"/>  <!-- Zone 3: Favoriten -->
                                                    <RowDefinition Height="Auto"/>  <!-- Sep: before groups -->
                                                    <RowDefinition Height="*"/>     <!-- Zone 4: Scrollable groups -->
                                                    <RowDefinition Height="Auto"/>  <!-- Resize grip -->
                                                </Grid.RowDefinitions>

                                                <!-- Zone 1: Search box — fixed one-line height -->
                                                <TextBox Grid.Row="0"
                                                         x:Name="FieldSelectorSearchBox"
                                                         Text="{Binding Data.FieldSelectorFilterText, Source={StaticResource VmProxy}, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="4,4,4,2"
                                                         Padding="4,3"
                                                         FontSize="11"
                                                         Height="26"
                                                         TextWrapping="NoWrap"
                                                         VerticalAlignment="Top"
                                                         BorderThickness="1"
                                                         PreviewKeyDown="FieldSelectorSearchBox_PreviewKeyDown">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                            <Setter Property="Foreground" Value="{DynamicResource CheckupPrimaryText}"/>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>

                                                <!-- Zone 2: Fixed actions (Add/Remove Row + kein Feld) — never filtered -->
                                                <ItemsControl Grid.Row="1"
                                                              ItemsSource="{Binding Data.StickyFieldItems, Source={StaticResource VmProxy}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Click="FieldSelectorItem_Click"
                                                                    HorizontalContentAlignment="Left"
                                                                    Padding="6,3"
                                                                    Cursor="Hand"
                                                                    ToolTip="{DynamicResource FieldSel_PinTooltip}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="bdr" Background="Transparent">
                                                                            <TextBlock x:Name="txt"
                                                                                       Text="{Binding DropText}"
                                                                                       FontSize="11"
                                                                                       Foreground="{DynamicResource CheckupPrimaryText}"
                                                                                       Padding="6,3"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                            </Trigger>
                                                                            <DataTrigger Binding="{Binding IsActionItem}" Value="True">
                                                                                <Setter TargetName="txt" Property="FontWeight" Value="SemiBold"/>
                                                                                <Setter TargetName="txt" Property="Foreground" Value="{DynamicResource CheckupActionItemForeground}"/>
                                                                            </DataTrigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Separator — shown only when Favoriten zone is non-empty -->
                                                <Separator Grid.Row="2" Margin="4,0" Background="{DynamicResource CheckupButtonBorder}">
                                                    <Separator.Style>
                                                        <Style TargetType="Separator">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Data.HasPinnedItems, Source={StaticResource VmProxy}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Separator.Style>
                                                </Separator>

                                                <!-- Zone 3: Favoriten (user-pinned) — hidden when empty -->
                                                <ItemsControl Grid.Row="3"
                                                              ItemsSource="{Binding Data.FavoritenItems, Source={StaticResource VmProxy}}">
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Data.HasPinnedItems, Source={StaticResource VmProxy}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <!-- Outer Border owns hover, right-click, and drop.
                                                                 Drag handle is a sibling of the Button (not inside it)
                                                                 so WPF's button mouse-capture cannot block MouseMove. -->
                                                            <Border Background="Transparent"
                                                                    AllowDrop="True"
                                                                    DragEnter="FavoritenItem_DragEnter"
                                                                    Drop="FavoritenItem_Drop"
                                                                    MouseRightButtonUp="FieldSelectorItem_RightClick"
                                                                    ToolTip="{DynamicResource FieldSel_PinTooltip}">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Style.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                            </Trigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="18"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- Drag handle — outside Button, so MouseMove fires freely -->
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="≡"
                                                                               FontSize="10"
                                                                               Foreground="{DynamicResource CheckupDragHandleFill}"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Center"
                                                                               Cursor="SizeNS"
                                                                               MouseMove="FavoritenDragHandle_MouseMove"/>
                                                                    <!-- Clickable label -->
                                                                    <Button Grid.Column="1"
                                                                            Click="FieldSelectorPinned_Click"
                                                                            Cursor="Hand"
                                                                            Padding="0">
                                                                        <Button.Template>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border Background="Transparent">
                                                                                    <StackPanel Orientation="Horizontal" Margin="2,3,6,3">
                                                                                        <TextBlock x:Name="sTag"
                                                                                                   Text="S: "
                                                                                                   FontSize="11"
                                                                                                   FontWeight="SemiBold"
                                                                                                   Foreground="{DynamicResource CheckupErrorText}"
                                                                                                   Visibility="Collapsed"/>
                                                                                        <TextBlock x:Name="txt"
                                                                                                   Text="{Binding DropText}"
                                                                                                   FontSize="11"
                                                                                                   Foreground="{DynamicResource CheckupPrimaryText}"/>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsSpecialEntry}" Value="True">
                                                                                        <Setter TargetName="sTag" Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                                                        <Setter TargetName="txt" Property="TextDecorations" Value="Strikethrough"/>
                                                                                        <Setter TargetName="txt" Property="Foreground" Value="{DynamicResource CheckupSecondaryText}"/>
                                                                                    </DataTrigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Button.Template>
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Separator before scrollable groups -->
                                                <Separator Grid.Row="4" Margin="4,0"
                                                           Background="{DynamicResource CheckupButtonBorder}"/>

                                                <!-- Zone 4: Scrollable collapsible groups -->
                                                <ScrollViewer Grid.Row="5"
                                                              VerticalScrollBarVisibility="Auto"
                                                              CanContentScroll="False">
                                                    <ItemsControl ItemsSource="{Binding Data.ScrollableGroups, Source={StaticResource VmProxy}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel>
                                                                    <!-- Group header row: chevron + label -->
                                                                    <Button Click="FieldSelectorGroupHeader_Click"
                                                                            HorizontalContentAlignment="Left"
                                                                            Padding="0"
                                                                            IsEnabled="{Binding IsChevronEnabled}">
                                                                        <Button.Template>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border Background="{DynamicResource CheckupGroupHeaderBackground}">
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="16"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Grid.Column="0"
                                                                                                   x:Name="chevron"
                                                                                                   Text="▶"
                                                                                                   FontSize="8"
                                                                                                   Foreground="{DynamicResource CheckupGroupHeaderForeground}"
                                                                                                   VerticalAlignment="Center"
                                                                                                   HorizontalAlignment="Center"/>
                                                                                        <TextBlock Grid.Column="1"
                                                                                                   Text="{Binding GroupDisplayName}"
                                                                                                   FontSize="10" FontWeight="Bold"
                                                                                                   Foreground="{DynamicResource CheckupGroupHeaderForeground}"
                                                                                                   Padding="2,2,6,2"/>
                                                                                    </Grid>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                        <Setter TargetName="chevron" Property="Text" Value="▼"/>
                                                                                    </DataTrigger>
                                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                                        <Setter TargetName="chevron" Property="Visibility" Value="Collapsed"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Button.Template>
                                                                    </Button>
                                                                    <!-- Group items — collapsed when IsCollapsed -->
                                                                    <ItemsControl ItemsSource="{Binding FilteredItems}" AlternationCount="2">
                                                                        <ItemsControl.Style>
                                                                            <Style TargetType="ItemsControl">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ItemsControl.Style>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid>
                                                                                    <Border x:Name="rowBg" Background="{DynamicResource CheckupRowBackground0}"/>
                                                                                    <Button Click="FieldSelectorItem_Click"
                                                                                            MouseRightButtonUp="FieldSelectorItem_RightClick"
                                                                                            HorizontalContentAlignment="Left"
                                                                                            Padding="0"
                                                                                            Cursor="Hand"
                                                                                            ToolTip="{DynamicResource FieldSel_PinTooltip}">
                                                                                        <Button.Template>
                                                                                            <ControlTemplate TargetType="Button">
                                                                                                <Border x:Name="bdr" Background="Transparent">
                                                                                                    <DockPanel LastChildFill="True">
                                                                                                        <Rectangle DockPanel.Dock="Bottom"
                                                                                                                   Height="1"
                                                                                                                   Stroke="{DynamicResource CheckupSeparator}"
                                                                                                                   StrokeThickness="1"
                                                                                                                   StrokeDashArray="1 2"
                                                                                                                   SnapsToDevicePixels="True"/>
                                                                                                        <StackPanel Orientation="Horizontal" Margin="14,3,6,2">
                                                                                                            <TextBlock x:Name="sTag"
                                                                                                                       Text="S: "
                                                                                                                       FontSize="11"
                                                                                                                       FontWeight="SemiBold"
                                                                                                                       Foreground="{DynamicResource CheckupErrorText}"
                                                                                                                       Visibility="Collapsed"/>
                                                                                                            <TextBlock Text="{Binding DropText}"
                                                                                                                       FontSize="11"
                                                                                                                       Foreground="{DynamicResource CheckupPrimaryText}"/>
                                                                                                        </StackPanel>
                                                                                                    </DockPanel>
                                                                                                </Border>
                                                                                                <ControlTemplate.Triggers>
                                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                                        <Setter TargetName="bdr" Property="Background" Value="{DynamicResource CheckupComboItemHoverBackground}"/>
                                                                                                    </Trigger>
                                                                                                    <DataTrigger Binding="{Binding IsSpecialEntry}" Value="True">
                                                                                                        <Setter TargetName="sTag" Property="Visibility" Value="Visible"/>
                                                                                                    </DataTrigger>
                                                                                                </ControlTemplate.Triggers>
                                                                                            </ControlTemplate>
                                                                                        </Button.Template>
                                                                                    </Button>
                                                                                </Grid>
                                                                                <DataTemplate.Triggers>
                                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}" Value="1">
                                                                                        <Setter TargetName="rowBg" Property="Background" Value="{DynamicResource CheckupRowBackground1}"/>
                                                                                    </DataTrigger>
                                                                                </DataTemplate.Triggers>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>

                                                <!-- Resize grip (height only — width auto-sizes to content) -->
                                                <Thumb Grid.Row="6"
                                                       HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                       Width="12" Height="12" Cursor="SizeNS"
                                                       DragDelta="FieldSelectorResizeThumb_DragDelta">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Path Data="M 0 12 L 12 0 M 4 12 L 12 4 M 8 12 L 12 8"
                                                                  Stroke="{DynamicResource CheckupSecondaryText}"
                                                                  StrokeThickness="1.5"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Grid>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- Col 2: Apply + Cancel (visible only when value has actually changed) -->
                                <StackPanel Grid.Row="0" Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center" Margin="2,1"
                                            Visibility="{Binding HasValueChanged, Converter={StaticResource BoolToVis}}">
                                    <Button Content="{DynamicResource Btn_Apply}"
                                            FontSize="11"
                                            Background="{DynamicResource CheckupApplyButtonBackground}"
                                            Foreground="{DynamicResource CheckupButtonForeground}"
                                            BorderBrush="{DynamicResource CheckupButtonBorder}"
                                            Margin="0,0,4,0" Padding="8,2" Height="24"
                                            IsEnabled="{Binding IsEditValueValid}"
                                            Command="{Binding DataContext.ApplyFieldEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Tip_Apply}"/>
                                    <Button Foreground="{DynamicResource CheckupButtonForeground}"
                                            Background="{DynamicResource CheckupCancelButtonBackground}"
                                            BorderBrush="{DynamicResource CheckupButtonBorder}"
                                            Width="24" Height="24"
                                            Command="{Binding DataContext.CancelFieldEditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{DynamicResource Tip_Cancel}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1">
                                                    <TextBlock Text="✕" FontSize="12" FontWeight="Bold"
                                                               Foreground="{TemplateBinding Foreground}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Opacity" Value="0.6"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <!-- Col 2: Expert pending-apply button — shrunk to label width so Field Selector
                                     remains clickable on the right. Declared last → highest z-order in this cell. -->
                                <Button Grid.Row="0" Grid.Column="2"
                                        HorizontalAlignment="Left"
                                        FontSize="11"
                                        Background="{DynamicResource CheckupApplyButtonBackground}"
                                        Foreground="{DynamicResource CheckupButtonForeground}"
                                        BorderBrush="{DynamicResource CheckupButtonBorder}"
                                        BorderThickness="1"
                                        Margin="2,1,2,1" Height="24"
                                        Command="{Binding DataContext.ApplyExpertValueCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{DynamicResource Btn_ExpertApply}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="6,0"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsExpertPendingApply}" Value="True"/>
                                                        <Condition Binding="{Binding IsInlineEditing}"      Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <!-- Bottom separator line -->
                                <Rectangle Grid.Row="1" Grid.ColumnSpan="3"
                                           Height="1"
                                           Stroke="{DynamicResource CheckupSeparator}"
                                           StrokeDashArray="2 2"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
