<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="CheckupWindowBackground"            Color="#F0F0F0"/>
    <SolidColorBrush x:Key="CheckupRowBackground0"              Color="#F0F0F0"/>
    <SolidColorBrush x:Key="CheckupRowBackground1"              Color="#EFF2F7"/>
    <SolidColorBrush x:Key="CheckupPrimaryText"                 Color="#000000"/>
    <SolidColorBrush x:Key="CheckupSecondaryText"               Color="#5C5C5C"/>
    <SolidColorBrush x:Key="CheckupLabelText"                   Color="#323232"/>
    <SolidColorBrush x:Key="CheckupErrorText"                   Color="#CC0000"/>
    <SolidColorBrush x:Key="CheckupSeparator"                   Color="#D0D0D0"/>
    <SolidColorBrush x:Key="CheckupButtonBackground"            Color="#E8E8E8"/>
    <SolidColorBrush x:Key="CheckupButtonBorder"                Color="#C0C0C0"/>
    <SolidColorBrush x:Key="CheckupButtonForeground"            Color="#000000"/>
    <SolidColorBrush x:Key="CheckupSpecialButtonBackground"     Color="#FFEBD2"/>
    <SolidColorBrush x:Key="CheckupDestructiveButtonBackground" Color="#FFD2D2"/>
    <SolidColorBrush x:Key="CheckupApplyButtonBackground"       Color="#DCEBFF"/>
    <SolidColorBrush x:Key="CheckupCancelButtonBackground"      Color="#FFD2D2"/>
    <SolidColorBrush x:Key="CheckupActionItemForeground"        Color="#1A6FBF"/>
    <SolidColorBrush x:Key="CheckupGroupHeaderBackground"       Color="#EEEEEE"/>
    <SolidColorBrush x:Key="CheckupGroupHeaderForeground"       Color="#505050"/>
    <SolidColorBrush x:Key="CheckupDragHandleFill"              Color="#AAAAAA"/>
    <SolidColorBrush x:Key="CheckupDragHighlight"               Color="#66BCE3"/>
    <!-- Option C toggle-button active state tokens (§5.3, §5.8, §6.3) -->
    <SolidColorBrush x:Key="CheckupPresetActiveBorder"          Color="#0696D7"/>
    <SolidColorBrush x:Key="CheckupPresetActiveBackground"      Color="#140696D7"/>
    <SolidColorBrush x:Key="CheckupSelectedCardBackground"      Color="#66BCE3"/>
    <!-- Drag-over highlight background (Group border background when IsDragOver=True) -->
    <SolidColorBrush x:Key="CheckupSelectedRowBackground"       Color="#C0DCF5"/>
    <SolidColorBrush x:Key="CheckupLinkStripe"                  Color="#4E9BD6"/>
    <SolidColorBrush x:Key="CheckupSyncStripe"                  Color="#A06020"/>
    <SolidColorBrush x:Key="CheckupComboItemBackground"         Color="#F0F0F0"/>
    <SolidColorBrush x:Key="CheckupComboItemHoverBackground"    Color="#D8E8FB"/>
    <SolidColorBrush x:Key="CheckupTabActiveBackground"          Color="#F3F3F3"/>
    <SolidColorBrush x:Key="CheckupTabInactiveBackground"        Color="#E0E0E0"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"     Color="#66BCE3"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>

    <Style TargetType="TextBox">
        <Setter Property="Background"  Value="#FFFFFF"/>
        <Setter Property="Foreground"  Value="#000000"/>
        <Setter Property="BorderBrush" Value="#ABADB3"/>
    </Style>

    <!-- Scrollbar colors (§5.15) -->
    <SolidColorBrush x:Key="CheckupScrollBarThumb"      Color="#AAAAAA"/>
    <SolidColorBrush x:Key="CheckupScrollBarThumbHover" Color="#888888"/>
    <!-- Alias used by LogicDropdownPopupContent border background -->
    <SolidColorBrush x:Key="CheckupComboBoxBackground"  Color="#F0F0F0"/>
    <!-- Background for editable TextBoxes inside custom panels (AllowedValues, Logic dropdown) -->
    <SolidColorBrush x:Key="CheckupEditableBackground"  Color="#FFFFFF"/>

    <!-- ─── Modern thin scrollbar (Windows 11 / Inventor 2026 style) — §5.15 ─── -->
    <Style x:Key="ModernScrollBarThumb" TargetType="{x:Type Thumb}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid Background="Transparent">
                        <Border x:Name="ThumbBorder"
                                CornerRadius="3"
                                Background="{DynamicResource CheckupScrollBarThumb}"
                                Margin="2,2,2,2"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource CheckupScrollBarThumbHover}"/>
                            <Setter TargetName="ThumbBorder" Property="Margin"     Value="1,1,1,1"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource CheckupScrollBarThumbHover}"/>
                            <Setter TargetName="ThumbBorder" Property="Margin"     Value="1,1,1,1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernScrollBarPageButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="8"/>
                <Setter Property="Width"  Value="Auto"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Border Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ModernScrollBarPageButton}"
                                                      Command="ScrollBar.PageLeftCommand"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ModernScrollBarPageButton}"
                                                      Command="ScrollBar.PageRightCommand"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width"  Value="8"/>
                <Setter Property="Height" Value="Auto"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Border Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ModernScrollBarPageButton}"
                                                      Command="ScrollBar.PageUpCommand"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ModernScrollBarPageButton}"
                                                      Command="ScrollBar.PageDownCommand"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
