<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0-windows</TargetFramework>
		<UseWPF>true</UseWPF>
		<Platforms>x64</Platforms>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<EnableComHosting>true</EnableComHosting>
		<Nullable>disable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<RootNamespace>CheckupAddIn</RootNamespace>
		<AssemblyName>CheckupAddIn</AssemblyName>
		<GenerateAssemblyInfo>true</GenerateAssemblyInfo>
		<Version>0.15.0</Version>
		<Author>Norman Lindner</Author>
		<Description>Checkup for Autodesk Inventor 2027</Description>
		<OutputPath>bin\</OutputPath>
		<AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
		<AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
	</PropertyGroup>

	<Import Project="..\..\CheckupAddin.Shared\CheckupAddin.Shared.projitems" Label="Shared" />

	<ItemGroup>
		<Reference Include="Autodesk.Inventor.Interop">
			<HintPath>..\..\lib\2027\Autodesk.Inventor.Interop.dll</HintPath>
			<EmbedInteropTypes>false</EmbedInteropTypes>
			<Private>true</Private>
		</Reference>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="System.Drawing.Common" Version="8.0.0" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="Icon Checkup.png">
			<LogicalName>CheckupAddIn.checkup_icon.png</LogicalName>
		</EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<Page Include="..\..\CheckupAddin2026\CheckupAddin2026\Resources\DarkTheme.xaml">
			<Link>Resources\DarkTheme.xaml</Link>
		</Page>
		<Page Include="..\..\CheckupAddin2026\CheckupAddin2026\Resources\LightTheme.xaml">
			<Link>Resources\LightTheme.xaml</Link>
		</Page>
		<Page Include="..\..\CheckupAddin2026\CheckupAddin2026\Resources\Languages\Addin_Language_File_DE.xaml">
			<Link>Resources\Languages\Addin_Language_File_DE.xaml</Link>
		</Page>
	</ItemGroup>

	<ItemGroup>
		<None Update="Autodesk.CheckupAddIn2027.addin">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
		<None Update="Checkup_Settings.json">
			<CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
		<None Include="..\..\CheckupAddin2026\CheckupAddin2026\Resources\Languages\Addin_Language_File_DE.json">
			<Link>Resources\Languages\Addin_Language_File_DE.json</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>Languages\Addin_Language_File_DE.json</TargetPath>
		</None>
		<None Include="..\..\CheckupAddin2026\CheckupAddin2026\Resources\Languages\Addin_Language_File_EN.json">
			<Link>Resources\Languages\Addin_Language_File_EN.json</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>Languages\Addin_Language_File_EN.json</TargetPath>
		</None>
<None Update="Checkup_Catalogs.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
		<None Update="Checkup_Capabilities.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
		<None Update="Resources\Test_Spezifik.capability.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>Capabilities\Test_Spezifik.capability.json</TargetPath>
		</None>
		<None Update="Resources\Test_Spezifik.feature-kombis.catalog.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>Catalogs\Test_Spezifik.feature-kombis.catalog.json</TargetPath>
		</None>		<None Update="Resources\Test_Spezifik.catalog.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>Catalogs\Test_Spezifik.catalog.json</TargetPath>
		</None>
		<None Update="Resources\Demo.capability.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>Capabilities\Demo.capability.json</TargetPath>
		</None>
		<None Update="Resources\Demo.catalog.json">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<TargetPath>Catalogs\Demo.catalog.json</TargetPath>
		</None>
		<None Include="Bereinigen IDW+IPT+IAM.iLogicVb" />
	</ItemGroup>

	<!-- Create empty Catalogs\ and Capabilities\ subfolders in the output directory.
	     Condition prevents touching existing directories (MakeDir is already idempotent,
	     but the explicit Condition makes the intent clear). -->
	<Target Name="CreateDevSubfolders" AfterTargets="Build">
		<MakeDir Directories="$(OutputPath)Catalogs"      Condition="!Exists('$(OutputPath)Catalogs')"/>
		<MakeDir Directories="$(OutputPath)Capabilities"  Condition="!Exists('$(OutputPath)Capabilities')"/>
	</Target>

</Project>
