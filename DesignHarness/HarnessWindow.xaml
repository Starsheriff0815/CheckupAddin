<Window x:Class="CheckupAddIn.DesignHarness.HarnessWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Checkup Design Harness" Width="460" Height="800"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI" FontSize="12">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Preview launcher -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Checkup Design Harness" FontSize="16" FontWeight="Bold"/>
            <TextBlock Text="Live-preview the add-in windows with dummy data — no Inventor. Changes apply to the open preview; Export writes colors back to the theme file."
                       TextWrapping="Wrap" Foreground="Gray" Margin="0,2,0,6"/>
            <ComboBox x:Name="WindowPicker" SelectedIndex="0" Margin="0,0,0,4">
                <ComboBoxItem Content="Main window (CheckupWindow)"/>
                <ComboBoxItem Content="Logics-Constructor (Catalog + Capabilities)"/>
                <ComboBoxItem Content="Catalog Picker"/>
                <ComboBoxItem Content="Info — Main window help"/>
                <ComboBoxItem Content="Info — Logics-Constructor (Roles)"/>
                <ComboBoxItem Content="Info — Logics-Constructor (Cards)"/>
                <ComboBoxItem Content="Input dialog"/>
                <ComboBoxItem Content="Preset Picker dialog"/>
            </ComboBox>
            <Button x:Name="OpenBtn" Content="Open / Reload Preview" Padding="8,4" Click="OpenBtn_Click"/>
        </StackPanel>

        <!-- Theme -->
        <GroupBox Grid.Row="1" Header="Theme" Margin="0,0,0,8" Padding="6">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="ThemeDark"  Content="Dark"  IsChecked="True" Margin="0,0,16,0" Checked="Theme_Changed"/>
                <RadioButton x:Name="ThemeLight" Content="Light" Checked="Theme_Changed"/>
            </StackPanel>
        </GroupBox>

        <!-- Font -->
        <GroupBox Grid.Row="2" Header="Font" Margin="0,0,0,8" Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Family" VerticalAlignment="Center" Margin="0,0,8,4"/>
                <ComboBox x:Name="FontFamilyBox" Grid.Row="0" Grid.Column="1" SelectedIndex="0" Margin="0,0,0,4"
                          SelectionChanged="FontFamily_Changed">
                    <ComboBoxItem Content="Segoe UI"/>
                    <ComboBoxItem Content="Segoe UI Variable"/>
                    <ComboBoxItem Content="Calibri"/>
                    <ComboBoxItem Content="Arial"/>
                    <ComboBoxItem Content="Tahoma"/>
                    <ComboBoxItem Content="Verdana"/>
                    <ComboBoxItem Content="Consolas"/>
                </ComboBox>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Size" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                    <Slider x:Name="FontSizeSlider" Width="220" Minimum="8" Maximum="22" Value="12"
                            TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="FontSize_Changed"/>
                    <TextBlock x:Name="FontSizeLabel" Text="12 pt" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Size -->
        <GroupBox Grid.Row="3" Header="Window size" Margin="0,0,0,8" Padding="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="W" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBox x:Name="WidthBox" Width="60" Text="650"/>
                <TextBlock Text="H" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <TextBox x:Name="HeightBox" Width="60" Text="900"/>
                <Button Content="Apply size" Padding="8,2" Margin="12,0,0,0" Click="ApplySize_Click"/>
                <Button Content="Export → XAML" Padding="8,2" Margin="8,0,0,0" Click="ExportSize_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- Colors + Labels editors -->
        <TabControl Grid.Row="4">
            <TabItem Header="Colors">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="ColorList" Grid.Row="0" SelectionChanged="ColorList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="20" Height="14" BorderBrush="Gray" BorderThickness="1"
                                            Background="{Binding Brush}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Hex}" Width="80" FontFamily="Consolas"/>
                                    <TextBlock Text="{Binding Key}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Hex" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="HexBox" Width="100" FontFamily="Consolas"/>
                        <Button Content="Apply color" Padding="8,2" Margin="8,0,0,0" Click="ApplyColor_Click"/>
                        <Button x:Name="ExportBtn" Content="Export → theme file" Padding="8,2" Margin="16,0,0,0" Click="Export_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Labels">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Language" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="LangBox" Width="80" SelectedIndex="0" SelectionChanged="Lang_Changed">
                            <ComboBoxItem Content="DE"/>
                            <ComboBoxItem Content="EN"/>
                        </ComboBox>
                    </StackPanel>
                    <ListBox x:Name="LabelList" Grid.Row="1" SelectionChanged="LabelList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Key}" Width="190" FontFamily="Consolas" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Value}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Margin="0,6,0,0">
                        <TextBlock x:Name="LabelKeyText" Text="(select a label)" FontFamily="Consolas" Foreground="Gray"/>
                        <TextBox x:Name="LabelValueBox" Margin="0,2,0,0" MinHeight="40"
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="Apply label" Padding="8,2" Click="ApplyLabel_Click"/>
                            <Button Content="Export → language JSON" Padding="8,2" Margin="16,0,0,0" Click="ExportLabels_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status -->
        <TextBlock x:Name="StatusText" Grid.Row="5" Margin="0,8,0,0" Foreground="DarkSlateGray" TextWrapping="Wrap"
                   Text="Click 'Open / Reload Preview' to start."/>
    </Grid>
</Window>
